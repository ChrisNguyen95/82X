{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.54 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.54 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ── Heading alignment & max-width ── */
  .section-{{ section.id }}-padding .title {
    text-align: {{ section.settings.heading_align | default: 'center' }};
    margin-bottom: 4rem
  }
  {%- if section.settings.heading_max_width > 0 %}
  .section-{{ section.id }}-padding .title {
    max-width: {{ section.settings.heading_max_width }}px;
    margin-left: {% if section.settings.heading_align == 'center' %}auto{% else %}0{% endif %};
    margin-right: {% if section.settings.heading_align == 'center' %}auto{% else %}0{% endif %};
  }
  {%- endif %}

   @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding .title {
        margin-bottom: 5rem
      }
    }
{%- endstyle -%}
<div class="color-{{ section.settings.color_scheme }} gradient">
    
  <div class="{% if section.settings.include_margins %}page-width{% endif %} section-{{ section.id }}-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {%- unless section.settings.title == blank -%}
        <h2 class="title {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
    {%- endunless -%}

    {%- for block in section.blocks -%}
      {% render block %}
    {%- endfor -%}
  </div>
</div>
{% schema %}
{
  "name": "t:sections.apps.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "include_margins",
      "default": true,
      "label": "t:sections.apps.settings.include_margins.label"
    },
     {
      "type": "inline_richtext",
      "id": "title",
      "default": "t:sections.multicolumn.settings.title.default",
      "label": "t:sections.multicolumn.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_max_width",
      "min": 0,
      "max": 1200,
      "step": 40,
      "unit": "px",
      "label": "Heading max width",
      "default": 0,
      "info": "Set to 0 for no limit."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },    
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "t:sections.apps.presets.name"
    }
  ]
}
{% endschema %}
