{{- 'component-slider.css' | asset_url | stylesheet_tag -}}

{%- liquid
  assign col_desktop = 4
  assign col_mobile  = 2

  comment
    Tính padding-bottom % cho adapt ratio.
    Dùng aspect_ratio cao nhất (ảnh ngang nhất) để không cắt ảnh nào.
  endcomment
  assign highest_ar = 0
  for block in section.blocks
    if block.settings.image != blank and block.settings.image.aspect_ratio > highest_ar
      assign highest_ar = block.settings.image.aspect_ratio
    endif
  endfor
  if highest_ar == 0
    assign highest_ar = 1
  endif
  assign adapt_pb = 1 | divided_by: highest_ar | times: 100
-%}

{%- style -%}
/* ════════════════════════════════════════════════
   Ingredient Slider — #IngredientSlider-{{ section.id }}
   ════════════════════════════════════════════════ */

#IngredientSlider-{{ section.id }} {
  --ig-gap:    {{ section.settings.card_gap }}px;
  --ig-radius: {{ section.settings.card_radius }}px;

  background-color: {{ section.settings.background_color }};
  padding-top:    {{ section.settings.padding_top    | times: 0.75 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
}
@media screen and (min-width: 750px) {
  #IngredientSlider-{{ section.id }} {
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
}

/* ── Title ── */
#IngredientSlider-{{ section.id }} .ig-title {
  text-align: {{ section.settings.title_align }};
  margin: 0 0 4rem;
}

/* ════════════════════════════════════════════════
   SLIDER TRACK
   - Flexbox + overflow-x scroll
   - scroll-snap để dừng đúng thẻ
   - scroll-behavior: smooth để có hiệu ứng trượt
   ════════════════════════════════════════════════ */
#IngredientSlider-{{ section.id }} .ig-track {
  display: flex;
  flex-wrap: nowrap;
  gap: var(--ig-gap);
  list-style: none;
  margin: 0;
  padding: 0 0 0.4rem; /* chừa chỗ cho box-shadow card */

  overflow-x: scroll;          /* scroll (không phải auto) để JS Dawn nhận đúng */
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;     /* ← hiệu ứng trượt mượt */
  -webkit-overflow-scrolling: touch;

  /* Ẩn scrollbar mọi trình duyệt */
  scrollbar-width: none;
  -ms-overflow-style: none;
}
#IngredientSlider-{{ section.id }} .ig-track::-webkit-scrollbar {
  display: none;
}

/* ── Slide item — chiều rộng cố định ── */
#IngredientSlider-{{ section.id }} .ig-item {
  /* Mobile: hiện {{ col_mobile }} cột */
  flex: 0 0 calc((100% - {{ col_mobile | minus: 1 }} * var(--ig-gap)) / {{ col_mobile }});
  max-width: calc((100% - {{ col_mobile | minus: 1 }} * var(--ig-gap)) / {{ col_mobile }});
  scroll-snap-align: start;
  min-width: 0;
}
@media screen and (min-width: 990px) {
  #IngredientSlider-{{ section.id }} .ig-item {
    /* Desktop: hiện {{ col_desktop }} cột */
    flex: 0 0 calc((100% - {{ col_desktop | minus: 1 }} * var(--ig-gap)) / {{ col_desktop }});
    max-width: calc((100% - {{ col_desktop | minus: 1 }} * var(--ig-gap)) / {{ col_desktop }});
  }
}

/* ════════════════════════════════════════════════
   CARD
   ════════════════════════════════════════════════ */
#IngredientSlider-{{ section.id }} .ig-card {
  display: flex;
  flex-direction: column;
  height: 100%;
  text-align: {{ section.settings.card_text_align }};
}

/* ── Image wrapper ──
   Luôn position: relative để img absolute fill vào.
   Chiều cao đến từ padding-bottom (adapt) hoặc aspect-ratio (fixed).
────────────────────────────────────────────────── */
#IngredientSlider-{{ section.id }} .ig-card__img-wrap {
  position: relative;
  width: 100%;
  overflow: hidden;
  border-radius: var(--ig-radius);
  background-color: {{ section.settings.card_bg }};

  {%- if section.settings.image_ratio == 'adapt' -%}
    padding-bottom: {{ adapt_pb | round: 2 }}%;
  {%- elsif section.settings.image_ratio == 'square' -%}
    aspect-ratio: 1 / 1;
  {%- elsif section.settings.image_ratio == 'portrait' -%}
    aspect-ratio: 3 / 4;
  {%- elsif section.settings.image_ratio == 'landscape' -%}
    aspect-ratio: 4 / 3;
  {%- endif -%}
}

/* ── Image — luôn absolute để fill wrapper ── */
#IngredientSlider-{{ section.id }} .ig-card__img-wrap img,
#IngredientSlider-{{ section.id }} .ig-card__img-wrap .placeholder-svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: contain; /* contain: không cắt ảnh */
  display: block;
}

/* ── Info ── */
#IngredientSlider-{{ section.id }} .ig-card__info {
  padding: 1.6rem 0.4rem 0;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
#IngredientSlider-{{ section.id }} .ig-card__title {
  margin: 0;
  font-size: 1.6rem;
  font-weight: 700;
}
#IngredientSlider-{{ section.id }} .ig-card__text {
  margin: 0;
  font-size: 1.4rem;
  line-height: 1.55;
  opacity: 0.7;
}

/* ════════════════════════════════════════════════
   NAV BUTTONS — luôn hiển thị, căn giữa dưới slider
   ════════════════════════════════════════════════ */
#IngredientSlider-{{ section.id }} .ig-nav {
  display: flex !important;
  justify-content: center;
  align-items: center;
  gap: 1rem;
  margin-top: 3.2rem;
}

/* Override Dawn hide logic: hiển thị trên mọi breakpoint */
#IngredientSlider-{{ section.id }} .ig-nav .slider-button {
  display: flex !important;
  visibility: visible !important;
  width: 4.4rem;
  height: 4.4rem;
  padding: 0;
  border-radius: 50%;
  border: 0.15rem solid {{ section.settings.nav_color }};
  background: transparent;
  color: {{ section.settings.nav_color }};
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s ease, color 0.2s ease;
  flex-shrink: 0;
}
#IngredientSlider-{{ section.id }} .ig-nav .slider-button:hover:not([disabled]) {
  background: {{ section.settings.nav_color }};
  color: #fff;
}
#IngredientSlider-{{ section.id }} .ig-nav .slider-button[disabled] {
  opacity: 0.35;
  cursor: default;
}

/* Caret icon direction */
#IngredientSlider-{{ section.id }} .ig-nav .slider-button .svg-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 1.4rem;
  height: 1.4rem;
  pointer-events: none;
}
#IngredientSlider-{{ section.id }} .ig-nav .slider-button--prev .svg-wrapper { transform: rotate(90deg); }
#IngredientSlider-{{ section.id }} .ig-nav .slider-button--next .svg-wrapper { transform: rotate(-90deg); }
{%- endstyle -%}

<section
  id="IngredientSlider-{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} gradient{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
>
  <div class="page-width">

    {%- unless section.settings.title == blank -%}
      <h2 class="ig-title inline-richtext {{ section.settings.heading_size }}">
        {{- section.settings.title -}}
      </h2>
    {%- endunless -%}

    {%- comment -%}
      slider-component: Dawn custom element (assets/slider.js).
      Tự xử lý scroll prev/next qua aria-controls.
    {%- endcomment -%}
    <slider-component>

      <ul
        id="Slider-{{ section.id }}"
        class="ig-track"
        role="list"
      >
        {%- for block in section.blocks -%}
          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="ig-item"
            {{ block.shopify_attributes }}
          >
            <div class="ig-card">

              {%- comment -%}── Image wrapper ──{%- endcomment -%}
              <div class="ig-card__img-wrap">
                {%- if block.settings.image != blank -%}
                  {%- assign img_alt   = block.settings.image.alt | default: block.settings.title -%}
                  {%- assign img_sizes = '(min-width: 990px) 25vw, 50vw' -%}
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      widths: '200, 300, 400, 600, 800',
                      sizes: img_sizes,
                      alt: img_alt
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>

              {%- comment -%}── Text info ──{%- endcomment -%}
              <div class="ig-card__info">
                {%- if block.settings.title != blank -%}
                  <h3 class="ig-card__title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="ig-card__text rte">{{ block.settings.text }}</div>
                {%- endif -%}
              </div>

            </div>
          </li>
        {%- endfor -%}
      </ul>

      {%- comment -%}── Nav buttons ──{%- endcomment -%}
      <div class="ig-nav slider-buttons">
        <button
          type="button"
          class="slider-button slider-button--prev"
          name="previous"
          aria-label="{{ 'general.slider.previous_slide' | t }}"
          aria-controls="Slider-{{ section.id }}"
        >
          <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
        </button>
        <button
          type="button"
          class="slider-button slider-button--next"
          name="next"
          aria-label="{{ 'general.slider.next_slide' | t }}"
          aria-controls="Slider-{{ section.id }}"
        >
          <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
        </button>
      </div>

    </slider-component>

  </div>
</section>

{% schema %}
{
  "name": "Ingredient Slider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Ingredients You Can Recognize"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Title size",
      "options": [
        { "value": "h2",  "label": "Small" },
        { "value": "h1",  "label": "Medium" },
        { "value": "h0",  "label": "Large" },
        { "value": "hxl", "label": "Extra large" }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "title_align",
      "label": "Title alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Card image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image aspect ratio",
      "info": "\"Adapt to image\" giữ đúng tỉ lệ gốc, không cắt ảnh.",
      "options": [
        { "value": "adapt",     "label": "Adapt to image (original ratio)" },
        { "value": "square",    "label": "Square (1:1)" },
        { "value": "portrait",  "label": "Portrait (3:4)" },
        { "value": "landscape", "label": "Landscape (4:3)" }
      ],
      "default": "adapt"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Image background color",
      "default": "#D9E9F8"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Card corner radius",
      "default": 16
    },
    {
      "type": "select",
      "id": "card_text_align",
      "label": "Card text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Gap between cards",
      "default": 20
    },
    {
      "type": "header",
      "content": "Navigation buttons"
    },
    {
      "type": "color",
      "id": "nav_color",
      "label": "Button color",
      "default": "#1C2E5E"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Vitamin E"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Protects skin from free radicals and maintains moisture.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredient Slider",
      "blocks": [
        {
          "type": "ingredient",
          "settings": { "title": "Vitamin E", "text": "<p>Protects skin from free radicals and maintains moisture.</p>" }
        },
        {
          "type": "ingredient",
          "settings": { "title": "Grape Extract", "text": "<p>Supports skin regeneration and anti-aging benefits.</p>" }
        },
        {
          "type": "ingredient",
          "settings": { "title": "Pineapple Extract", "text": "<p>Improves skin elasticity and firmness.</p>" }
        },
        {
          "type": "ingredient",
          "settings": { "title": "Fermented Plant Extract", "text": "<p>Supports digestion, improves nutrient absorption, and detoxifies the body.</p>" }
        }
      ]
    }
  ]
}
{% endschema %}
