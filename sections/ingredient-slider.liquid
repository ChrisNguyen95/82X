{{- 'component-slider.css'    | asset_url | stylesheet_tag -}}
{{- 'custom-slider-nav.css'  | asset_url | stylesheet_tag -}}

{%- liquid
  assign col_desktop = 4
  assign col_mobile  = 2

  comment
    Tính padding-bottom % cho adapt ratio.
    Dùng aspect_ratio cao nhất (ảnh ngang nhất) để không cắt ảnh nào.
  endcomment
  assign highest_ar = 0
  for block in section.blocks
    if block.settings.image != blank and block.settings.image.aspect_ratio > highest_ar
      assign highest_ar = block.settings.image.aspect_ratio
    endif
  endfor
  if highest_ar == 0
    assign highest_ar = 1
  endif
  assign adapt_pb = 1 | divided_by: highest_ar | times: 100
-%}

{%- style -%}
/* ════════════════════════════════════════════════
   Ingredient Slider — #IngredientSlider-{{ section.id }}
   ════════════════════════════════════════════════ */

#IngredientSlider-{{ section.id }} {
  /* Gap mobile mặc định */
  --ig-gap:    {{ section.settings.card_gap_mobile }}px;
  --ig-radius: {{ section.settings.card_radius }}px;

  background-color: {{ section.settings.background_color }};
  padding-top:    {{ section.settings.padding_top    | times: 0.75 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
}
@media screen and (min-width: 750px) {
  #IngredientSlider-{{ section.id }} {
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
}
/* Gap desktop riêng biệt */
@media screen and (min-width: 990px) {
  #IngredientSlider-{{ section.id }} {
    --ig-gap: {{ section.settings.card_gap_desktop }}px;
  }
}

/* ── Title ── */
#IngredientSlider-{{ section.id }} .ig-title {
  text-align: {{ section.settings.title_align }};
  margin: 0 0 4rem;
}

/* ════════════════════════════════════════════════
   SLIDER TRACK
   - Flexbox + overflow-x scroll
   - scroll-snap để dừng đúng thẻ
   - scroll-behavior: smooth để có hiệu ứng trượt
   ════════════════════════════════════════════════ */
#IngredientSlider-{{ section.id }} .ig-track {
  display: flex;
  flex-wrap: nowrap;
  gap: var(--ig-gap);
  list-style: none;
  margin: 0;
  padding: 0 0 0.4rem; /* chừa chỗ cho box-shadow card */

  overflow-x: scroll;          /* scroll (không phải auto) để JS Dawn nhận đúng */
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;     /* ← hiệu ứng trượt mượt */
  -webkit-overflow-scrolling: touch;

  /* Ẩn scrollbar mọi trình duyệt */
  scrollbar-width: none;
  -ms-overflow-style: none;
}
#IngredientSlider-{{ section.id }} .ig-track::-webkit-scrollbar {
  display: none;
}

/* ── Slide item — chiều rộng cố định ── */
#IngredientSlider-{{ section.id }} .ig-item {
  /* Mobile: hiện {{ col_mobile }} cột */
  flex: 0 0 calc((100% - {{ col_mobile | minus: 1 }} * var(--ig-gap)) / {{ col_mobile }});
  max-width: calc((100% - {{ col_mobile | minus: 1 }} * var(--ig-gap)) / {{ col_mobile }});
  scroll-snap-align: start;
  min-width: 0;
}
@media screen and (min-width: 990px) {
  #IngredientSlider-{{ section.id }} .ig-item {
    /* Desktop: hiện {{ col_desktop }} cột */
    flex: 0 0 calc((100% - {{ col_desktop | minus: 1 }} * var(--ig-gap)) / {{ col_desktop }});
    max-width: calc((100% - {{ col_desktop | minus: 1 }} * var(--ig-gap)) / {{ col_desktop }});
  }
}

/* ════════════════════════════════════════════════
   CARD
   ════════════════════════════════════════════════ */
#IngredientSlider-{{ section.id }} .ig-card {
  display: flex;
  flex-direction: column;
  height: 100%;
  text-align: {{ section.settings.card_text_align }};
}

/* ── Image wrapper ──
   Luôn position: relative để img absolute fill vào.
   Chiều cao đến từ padding-bottom (adapt) hoặc aspect-ratio (fixed).
────────────────────────────────────────────────── */
#IngredientSlider-{{ section.id }} .ig-card__img-wrap {
  position: relative;
  width: 100%;
  overflow: hidden;
  border-radius: var(--ig-radius);
  background-color: {{ section.settings.card_bg }};

  {%- if section.settings.image_ratio == 'adapt' -%}
    padding-bottom: {{ adapt_pb | round: 2 }}%;
  {%- elsif section.settings.image_ratio == 'square' -%}
    aspect-ratio: 1 / 1;
  {%- elsif section.settings.image_ratio == 'portrait' -%}
    aspect-ratio: 3 / 4;
  {%- elsif section.settings.image_ratio == 'landscape' -%}
    aspect-ratio: 4 / 3;
  {%- endif -%}
}

/* ── Image — luôn absolute để fill wrapper ── */
#IngredientSlider-{{ section.id }} .ig-card__img-wrap img,
#IngredientSlider-{{ section.id }} .ig-card__img-wrap .placeholder-svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ── Info ── */
#IngredientSlider-{{ section.id }} .ig-card__info {
  padding: 1.6rem 0.4rem 0;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
#IngredientSlider-{{ section.id }} .ig-card__title {
  margin: 0;
  font-size: 1.6rem;
  font-weight: 600;
}
#IngredientSlider-{{ section.id }} .ig-card__text {
  margin: 0;
  font-size: 1.4rem;
  line-height: 1.55;
  opacity: 0.7;
}

/* Nav — override màu (styles chung trong custom-slider-nav.css) */
#IngredientSlider-{{ section.id }} .custom-slider-nav {
  --csn-color: {{ section.settings.nav_color }};
  margin-top: 3.2rem;
}

{%- endstyle -%}

<section
  id="IngredientSlider-{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} gradient{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
>
  <div class="page-width">

    {%- unless section.settings.title == blank -%}
      <h2 class="ig-title inline-richtext {{ section.settings.heading_size }}">
        {{- section.settings.title -}}
      </h2>
    {%- endunless -%}

    <ul
      id="ig-track-{{ section.id }}"
      class="ig-track"
      role="list"
    >
      {%- for block in section.blocks -%}
        <li
          id="ig-item-{{ section.id }}-{{ forloop.index }}"
          class="ig-item"
          {{ block.shopify_attributes }}
        >
          <div class="ig-card">

            {%- comment -%}── Image wrapper ──{%- endcomment -%}
            <div class="ig-card__img-wrap">
              {%- if block.settings.image != blank -%}
                {%- assign img_alt   = block.settings.image.alt | default: block.settings.title -%}
                {%- assign img_sizes = '(min-width: 990px) 25vw, 50vw' -%}
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    widths: '200, 300, 400, 600, 800',
                    sizes: img_sizes,
                    alt: img_alt
                }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>

            {%- comment -%}── Text info ──{%- endcomment -%}
            <div class="ig-card__info">
              {%- if block.settings.title != blank -%}
                <h3 class="ig-card__title">{{ block.settings.title | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="ig-card__text rte">{{ block.settings.text }}</div>
              {%- endif -%}
            </div>

          </div>
        </li>
      {%- endfor -%}
    </ul>

    {%- comment -%}── Nav buttons ──{%- endcomment -%}
    {%- render 'slider-nav-buttons',
      section_id: section.id,
      id_prefix:  'ig'
    -%}

  </div>
</section>

{%- assign _track_id = 'ig-track-' | append: section.id -%}
{%- assign _prev_id  = 'ig-prev-'  | append: section.id -%}
{%- assign _next_id  = 'ig-next-'  | append: section.id -%}
{%- render 'slider-loop-js',
  track_id:      _track_id,
  prev_id:       _prev_id,
  next_id:       _next_id,
  loop_enabled:  section.settings.loop_enabled,
  snap_center:   false,
  item_selector: '.ig-item',
  clone_class:   'ig-item--clone'
-%}

{% schema %}
{
  "name": "Ingredient Slider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Ingredients You Can Recognize"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Title size",
      "options": [
        { "value": "h2",  "label": "Small" },
        { "value": "h1",  "label": "Medium" },
        { "value": "h0",  "label": "Large" },
        { "value": "hxl", "label": "Extra large" }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "title_align",
      "label": "Title alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Card image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image aspect ratio",
      "info": "\"Adapt to image\" giữ đúng tỉ lệ gốc, không cắt ảnh.",
      "options": [
        { "value": "adapt",     "label": "Adapt to image (original ratio)" },
        { "value": "square",    "label": "Square (1:1)" },
        { "value": "portrait",  "label": "Portrait (3:4)" },
        { "value": "landscape", "label": "Landscape (4:3)" }
      ],
      "default": "adapt"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Image background color",
      "default": "#D9E9F8"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Card corner radius",
      "default": 16
    },
    {
      "type": "select",
      "id": "card_text_align",
      "label": "Card text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "card_gap_desktop",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Gap between cards (desktop)",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_gap_mobile",
      "min": 4,
      "max": 32,
      "step": 4,
      "unit": "px",
      "label": "Gap between cards (mobile)",
      "default": 12
    },
    {
      "type": "header",
      "content": "Navigation buttons"
    },
    {
      "type": "checkbox",
      "id": "loop_enabled",
      "label": "Enable loop (infinite scroll)",
      "info": "Khi bật: slider lặp vô hạn. Khi tắt: nút prev/next mờ đi ở biên đầu/cuối.",
      "default": false
    },
    {
      "type": "color",
      "id": "nav_color",
      "label": "Button color",
      "default": "#1C2E5E"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Vitamin E"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Protects skin from free radicals and maintains moisture.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredient Slider",
      "blocks": [
        {
          "type": "ingredient",
          "settings": { "title": "Vitamin E", "text": "<p>Protects skin from free radicals and maintains moisture.</p>" }
        },
        {
          "type": "ingredient",
          "settings": { "title": "Grape Extract", "text": "<p>Supports skin regeneration and anti-aging benefits.</p>" }
        },
        {
          "type": "ingredient",
          "settings": { "title": "Pineapple Extract", "text": "<p>Improves skin elasticity and firmness.</p>" }
        },
        {
          "type": "ingredient",
          "settings": { "title": "Fermented Plant Extract", "text": "<p>Supports digestion, improves nutrient absorption, and detoxifies the body.</p>" }
        }
      ]
    }
  ]
}
{% endschema %}
