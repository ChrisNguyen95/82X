{%- style -%}
  /* ── Padding ── */
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ══════════════════════════════════════════════
     STRUCTURAL CSS (all inline for Customize reliability)
     ══════════════════════════════════════════════ */

  /* ── Heading ── */
  #BlogHeader-{{ section.id }} .section-heading {
    text-align: {{ section.settings.heading_align }};
    margin-bottom: 3.2rem;
    max-width: {{ section.settings.heading_max_width }}px;
    {%- if section.settings.heading_align == 'center' %}
    margin-left: auto;
    margin-right: auto;
    {%- elsif section.settings.heading_align == 'right' %}
    margin-left: auto;
    margin-right: 0;
    {%- else %}
    margin-left: 0;
    margin-right: auto;
    {%- endif %}
  }

  /* ── Top bar wrapper ── */
  #BlogHeader-{{ section.id }} .blh-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    height: 6.4rem;
    border-top: 0.1rem solid {{ section.settings.border_color }};
    border-bottom: 0.1rem solid {{ section.settings.border_color }};
  }

  /* ── Nav links ── */
  #BlogHeader-{{ section.id }} .blh-nav {
    display: flex;
    align-items: center;
    height: 100%;
    flex: 1;
    overflow-x: auto;
    gap: 0;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  #BlogHeader-{{ section.id }} .blh-nav::-webkit-scrollbar { display: none; }

  #BlogHeader-{{ section.id }} .blh-nav__link {
    display: inline-flex;
    align-items: center;
    height: 100%;
    width: 17rem;
    flex-shrink: 0;
    font-weight: 450;
    font-size: 1.6rem;
    line-height: 2.4rem;
    letter-spacing: 0.02em;
    color: rgba(var(--color-foreground), 0.55);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s;
  }
  #BlogHeader-{{ section.id }} .blh-nav__link:hover {
    color: {{ section.settings.active_color }};
  }
  #BlogHeader-{{ section.id }} .blh-nav__link.is-active {
    color: {{ section.settings.active_color }};
    font-weight: 700;
  }

  /* ── Search — pill border 44px height, 444px width ── */
  #BlogHeader-{{ section.id }} .blh-search {
    flex-shrink: 0;
  }
  #BlogHeader-{{ section.id }} .blh-search__form {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    height: 4.4rem;
    width: 44.4rem;
    border: 0.1rem solid {{ section.settings.border_color }};
    border-radius: 0.8rem;
    padding: 0 1.6rem;
    background: transparent;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }
  #BlogHeader-{{ section.id }} .blh-search__form:focus-within {
    border-color: {{ section.settings.active_color }};
  }
  #BlogHeader-{{ section.id }} .blh-search__ico {
    width: 1.8rem;
    height: 1.8rem;
    color: rgba(var(--color-foreground), 0.45);
    flex-shrink: 0;
  }
  #BlogHeader-{{ section.id }} .blh-search__input {
    background: transparent;
    border: none;
    outline: none;
    flex: 1;
    font-size: 1.4rem;
    font-family: var(--font-body-family);
    color: rgba(var(--color-foreground), 0.7);
    padding: 0;
    height: 100%;
    line-height: 1;
  }
  #BlogHeader-{{ section.id }} .blh-search__input:focus-visible  {
    outline: none;
    box-shadow: none;
  }
  #BlogHeader-{{ section.id }} .blh-search__input::placeholder {
    color: rgba(var(--color-foreground), 0.4);
  }

  @media screen and (max-width: 989px) {
    #BlogHeader-{{ section.id }} .blh-search__form {
      width: 24rem;
    }
  }
  @media screen and (max-width: 749px) {
    #BlogHeader-{{ section.id }} .blh-topbar {
      height: auto;
      min-height: 5.6rem;
      flex-wrap: wrap;
      gap: 0;
      padding: 1.2rem 0;
    }
    #BlogHeader-{{ section.id }} .blh-nav {
      height: auto;
      order: 2;
      width: 100%;
    }
    #BlogHeader-{{ section.id }} .blh-nav__link {
      font-size: 1.4rem;
      padding: 0.8rem 1.6rem 0.8rem 0;
      height: auto;
      margin-bottom: 0;
    }
    #BlogHeader-{{ section.id }} .blh-search {
      order: 1;
      width: 100%;
    }
    #BlogHeader-{{ section.id }} .blh-search__form {
      width: 100%;
      height: 4rem;
    }
  }
{%- endstyle -%}

<section
  id="BlogHeader-{{ section.id }}"
  class="section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient"
>
  <div class="page-width">

    {%- comment -%}── Heading + Description ──{%- endcomment -%}
    {%- render 'section-heading',
      heading:        section.settings.heading,
      heading_tag:    section.settings.heading_tag,
      heading_size:   section.settings.heading_size,
      heading_align:  section.settings.heading_align,
      heading_italic: section.settings.heading_italic,
      subheading:     section.settings.subheading,
      description:    section.settings.description
    -%}

    {%- comment -%}── Top bar ──{%- endcomment -%}
    {%- if section.blocks.size > 0 or section.settings.show_search -%}
      <div class="blh-topbar">

        {%- comment -%}── Nav links (left) ──{%- endcomment -%}
        {%- if section.blocks.size > 0 -%}
          <nav class="blh-nav" aria-label="Blog navigation">
            {%- for block in section.blocks -%}
              {%- if block.type == 'nav_link' and block.settings.label != blank -%}
                {%- assign is_active = false -%}
                {%- if block.settings.link != blank -%}
                  {%- assign link_path = block.settings.link -%}
                  {%- if link_path == blog.url or request.path contains link_path -%}
                    {%- assign is_active = true -%}
                  {%- endif -%}
                {%- endif -%}
                <a
                  href="{{ block.settings.link | default: '#' }}"
                  class="blh-nav__link font-heading{% if is_active %} is-active{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.label | escape }}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </nav>
        {%- endif -%}

        {%- comment -%}── Search (right) ──{%- endcomment -%}
        {%- if section.settings.show_search -%}
          <div class="blh-search">
            <form
              action="{{ routes.search_url }}"
              method="get"
              class="blh-search__form"
              role="search"
            >
              <input type="hidden" name="type" value="article">
              <svg class="blh-search__ico" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
              <input
                type="search"
                name="q"
                class="blh-search__input"
                placeholder="{{ section.settings.search_placeholder | escape }}"
                aria-label="{{ section.settings.search_placeholder | escape }}"
                {% if search.terms != blank %}value="{{ search.terms | escape }}"{% endif %}
                autocomplete="off"
              >
            </form>
          </div>
        {%- endif -%}

      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Blog — Header",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Learning Center"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2",  "label": "Small" },
        { "value": "h1",  "label": "Medium" },
        { "value": "h0",  "label": "Large" },
        { "value": "hxl", "label": "Extra large" }
      ],
      "default": "h0"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading HTML tag",
      "options": [
        { "value": "h1", "label": "h1" },
        { "value": "h2", "label": "h2" },
        { "value": "h3", "label": "h3" }
      ],
      "default": "h1"
    },
    {
      "type": "checkbox",
      "id": "heading_italic",
      "label": "Italic heading",
      "default": true
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_max_width",
      "min": 400,
      "max": 1200,
      "step": 40,
      "unit": "px",
      "label": "Title & description max width",
      "default": 720
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Search"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search bar",
      "default": true
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search learning center"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "active_color",
      "label": "Active link color",
      "default": "#1C2B6B"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#E5E7EB"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Navigation link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Featured"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Blog link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog — Header",
      "blocks": [
        { "type": "nav_link", "settings": { "label": "Featured" } },
        { "type": "nav_link", "settings": { "label": "Skin & Anti-Aging" } },
        { "type": "nav_link", "settings": { "label": "Ingredient-Focused Content" } }
      ]
    }
  ]
}
{% endschema %}
