{%- style -%}
/* ══════════════════════════════════════════════════════════════
   Footer — #Footer-{{ section.id }}
   ══════════════════════════════════════════════════════════════ */

.footer {
  margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
}
@media screen and (min-width: 750px) {
  .footer { margin-top: {{ section.settings.margin_top }}px; }
}

/* ── Section padding ── */
.footer__top {
  padding-top:    {{ section.settings.padding_top    | times: 0.75 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
}
@media screen and (min-width: 990px) {
  .footer__top {
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
}

/* ══ Grid: Mobile 2-col, Desktop flex ════════════════════════ */

/* Mobile: 2-col grid */
.footer__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: {{ section.settings.row_gap_mobile }}px {{ section.settings.col_gap_mobile }}px;
}

/* Brand, Newsletter, Text → full width on mobile */
.footer-block--brand,
.footer-block--newsletter,
.footer-block--text {
  grid-column: 1 / -1;
}

/* Desktop: flexbox — each block width controlled by --footer-flex */
@media screen and (min-width: 990px) {
  .footer__grid {
    display: flex;
    flex-wrap: nowrap;
    align-items: flex-start;
    gap: {{ section.settings.col_gap_desktop }}px;
  }
  .footer-block {
    flex: var(--footer-flex, 1) var(--footer-flex, 1) 0;
    min-width: 0;
  }
  /* Reset full-width overrides from mobile */
  .footer-block--brand,
  .footer-block--newsletter,
  .footer-block--text {
    grid-column: auto;
  }
}

/* ══ Block shared ═════════════════════════════════════════════ */
.footer-block { display: flex; flex-direction: column; gap: 3rem; }

.footer-block__col-heading {
  margin: 0;
  font-size: 1.6rem;
  font-weight: 600;
  line-height: 1.3;
  color: var(--footer-heading-color, currentColor);
}

/* ══ Brand block ══════════════════════════════════════════════ */
.footer-block__logo { display: block; }
.footer-block__logo img { display: block; max-width: 100%; height: auto; }
.footer-block__details-content p {
  margin-bottom: 2rem;
}
.footer-block__tagline {
  margin: 0;
  font-size: 1.4rem;
  line-height: 1.6;
}

.footer-block__social-heading {
  margin-top: 0;
  margin-bottom: 1.6rem;
  font-size: 1.6rem;  
  font-weight: 600;
  font-family: var(--font-heading-family, inherit);
  color: var(--footer-heading-color);
}

.footer-block__disclaimer {
  padding: 1.2rem 1.6rem;
  border: 1px solid rgba(0, 0, 0, 0.14);
  border-radius: 4px;
  font-size: 1.2rem;
  font-style: italic;
  line-height: 1.6;
}
.footer-block__disclaimer > * { margin: 0; }

/* ══ Link list block ══════════════════════════════════════════ */
.footer-block__links {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 2rem;
}
.footer-block__links a {
  font-size: 1.4rem;
  color: inherit;
  text-decoration: none;
  line-height: 1.4;
}
.footer-block__links a:hover { text-decoration: underline; }

/* ══ Newsletter block ═════════════════════════════════════════ */
.footer-block--newsletter .footer-block__col-heading {
  font-size: 1.6rem;
}

.footer-block__newsletter-subtext {
  margin: 0;
  font-size: 1.4rem;
  line-height: 1.6;
}

/* Input field */
.footer-block__newsletter-field { position: relative; }

/* Full-width SUBSCRIBE button */
.footer-block__newsletter-submit {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 0.12em;
  font-weight: 600;
  margin-top: 2rem
}

.newsletter-form__message {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  font-size: 1.3rem;
  margin-top: 0.8rem;
}

/* Badge / image */
.footer-block__badge {
  display: flex;
  align-items: center;
  gap: 1.2rem;
  margin-top: 3rem;
}
.footer-block__badge img { display: block; height: auto; }
.footer-block__badge-text {
  font-size: 1.3rem;
  font-weight: 600;
  line-height: 1.3;
}
/* ══ Bottom bar: 2-col on ALL screens ════════════════════════ */

/* Row 1 (selector + payment): always flex row, space-between */
.footer__content-bottom-wrapper:first-child {
  flex-wrap: nowrap;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
}

/* Override Dawn's mobile full-width columns */
@media screen and (max-width: 749px) {
  .footer__content-bottom-wrapper:first-child {
    flex-wrap: nowrap;
    justify-content: space-between;
    row-gap: 0;
  }
  .footer__content-bottom-wrapper:first-child .footer__column {
    width: 50%;
  }
  .footer__column--info {
    align-items: flex-end;
  }
}
{%- endstyle -%}

{%- liquid
  assign has_social = true
  if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
    assign has_social = false
  endif
-%}

<footer class="footer color-{{ section.settings.color_scheme }} gradient">

  {%- comment -%}════════════ TOP ════════════{%- endcomment -%}
  <div class="footer__top">
    <div class="footer__grid page-width">

      {%- for block in section.blocks -%}
        {%- capture block_style -%}--footer-flex: {{ block.settings.col_size | default: 1 }};{%- unless block.settings.heading_color == blank %} --footer-heading-color: {{ block.settings.heading_color }};{%- endunless -%}{%- if settings.animations_reveal_on_scroll %} --animation-order: {{ forloop.index }};{%- endif -%}{%- endcapture -%}
        <div
          class="footer-block footer-block--{{ block.type }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          style="{{ block_style }}"
          {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}
          {{ block.shopify_attributes }}
        >

          {%- case block.type -%}

            {%- comment -%}── Brand ──{%- endcomment -%}
            {%- when 'brand' -%}
              {%- if block.settings.logo != blank -%}
                <a href="{{ routes.root_url }}" class="footer-block__logo">
                  {{
                    block.settings.logo
                    | image_url: width: 400
                    | image_tag:
                        loading: 'lazy',
                        widths: '100, 150, 200, 280, 400',
                        width: block.settings.logo_width,
                        alt: shop.name
                  }}
                </a>
              {%- endif -%}

              {%- unless block.settings.tagline == blank -%}
                <div class="footer-block__tagline rte">{{ block.settings.tagline }}</div>
              {%- endunless -%}

              {%- if block.settings.show_social and has_social -%}
                <div>
                {%- unless block.settings.social_heading == blank -%}
                  <p class="footer-block__social-heading">{{ block.settings.social_heading | escape }}</p>
                {%- endunless -%}
                {%- render 'social-icons', class: 'footer__list-social footer-block__brand-info' -%}
                </div>
              {%- endif -%}

              {%- unless block.settings.disclaimer == blank -%}
                <div class="footer-block__disclaimer">{{ block.settings.disclaimer }}</div>
              {%- endunless -%}

            {%- comment -%}── Link list ──{%- endcomment -%}
            {%- when 'link_list' -%}
              {%- unless block.settings.heading == blank -%}
                <p class="footer-block__col-heading font-heading">{{- block.settings.heading -}}</p>
              {%- endunless -%}
              {%- if block.settings.menu != blank -%}
                <ul class="footer-block__links" role="list">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a
                        href="{{ link.url }}"
                        {% if link.active %}aria-current="page"{% endif %}
                      >{{ link.title | escape }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

            {%- comment -%}── Text (e.g. Headquarters) ──{%- endcomment -%}
            {%- when 'text' -%}
              {%- unless block.settings.heading == blank -%}
                <p class="footer-block__col-heading font-heading">{{- block.settings.heading -}}</p>
              {%- endunless -%}
              {%- unless block.settings.subtext == blank -%}
                <div class="footer-block__details-content rte">{{ block.settings.subtext }}</div>
              {%- endunless -%}

            {%- comment -%}── Newsletter ──{%- endcomment -%}
            {%- when 'newsletter' -%}
              {%- unless block.settings.heading == blank -%}
                <p class="footer-block__col-heading font-heading">{{- block.settings.heading -}}</p>
              {%- endunless -%}

              {%- unless block.settings.subtext == blank -%}
                <p class="footer-block__newsletter-subtext">{{ block.settings.subtext | escape }}</p>
              {%- endunless -%}

              {%- form 'customer', id: 'ContactFooter', class: 'footer-block__newsletter-form' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">

                <div class="footer-block__newsletter-field field">
                  <input
                    id="NewsletterForm--{{ section.id }}"
                    type="email"
                    name="contact[email]"
                    class="field__input"
                    value="{{ form.email }}"
                    aria-required="true"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    {% if form.errors %}
                      autofocus
                      aria-invalid="true"
                      aria-describedby="ContactFooter-error"
                    {% elsif form.posted_successfully? %}
                      aria-describedby="ContactFooter-success"
                    {% endif %}
                    placeholder="{{ 'newsletter.label' | t }}"
                    required
                  >
                  <label class="field__label" for="NewsletterForm--{{ section.id }}">
                    {{ 'newsletter.label' | t }}
                  </label>
                </div>

                {%- if form.errors -%}
                  <small class="newsletter-form__message form__message" id="ContactFooter-error">
                    <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                    {{- form.errors.translated_fields.email | capitalize }}
                    {{ form.errors.messages.email -}}
                  </small>
                {%- endif -%}

                <button
                  type="submit"
                  class="button footer-block__newsletter-submit"
                  name="commit"
                >
                  {{- block.settings.button_label | default: 'SUBSCRIBE' | escape -}}
                </button>

                {%- if form.posted_successfully? -%}
                  <h3
                    class="newsletter-form__message newsletter-form__message--success form__message"
                    id="ContactFooter-success"
                    tabindex="-1"
                    autofocus
                  >
                    <span class="svg-wrapper">{{- 'icon-success.svg' | inline_asset_content -}}</span>
                    {{- 'newsletter.success' | t }}
                  </h3>
                {%- endif -%}
              {%- endform -%}

              {%- if block.settings.badge_image != blank -%}
                <div class="footer-block__badge">
                  {{
                    block.settings.badge_image
                    | image_url: width: 200
                    | image_tag:
                        loading: 'lazy',
                        width: block.settings.badge_image_width,
                        alt: block.settings.badge_text | default: ''
                  }}
                </div>
              {%- endif -%}

            {%- when '@app' -%}
              {% render block %}

          {%- endcase -%}
        </div>
      {%- endfor -%}

    </div>
  </div>

  {%- comment -%}════════════ BOTTOM BAR ════════════{%- endcomment -%}
  <div
    class="footer__content-bottom{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}
  >
    <div class="footer__content-bottom-wrapper page-width">

      <div class="footer__column footer__localization isolate">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
              <div>
                <h2 class="caption-large text-body" id="FooterCountryLabel">{{ 'localization.country_label' | t }}</h2>
                {%- render 'country-localization', localPosition: 'FooterCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
              <div>
                <h2 class="caption-large text-body" id="FooterLanguageLabel">{{ 'localization.language_label' | t }}</h2>
                {%- render 'language-localization', localPosition: 'FooterLanguage' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>

      <div class="footer__column footer__column--info">
        {%- if section.settings.payment_enable -%}
          <div class="footer__payment">
            <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
            <ul class="list list-payment" role="list">
              {%- for type in shop.enabled_payment_types -%}
                <li class="list-payment__item">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>

    </div>

    <div class="footer__content-bottom-wrapper page-width{% if section.settings.enable_country_selector == false and section.settings.enable_language_selector == false %} footer__content-bottom-wrapper--center{% endif %}">
      <div class="footer__copyright caption">
        <small class="copyright__content">
          &copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url -}}
        </small>
        <small class="copyright__content">{{ powered_by_link }}</small>
      </div>
    </div>
  </div>

</footer>

