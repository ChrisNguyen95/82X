{{ 'brand-sections.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- assign review_blocks = section.blocks | where: 'type', 'review' -%}

<div class="customer-reviews-82x color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">

    <!-- Section heading -->
    {%- if section.settings.heading != blank -%}
      <div class="customer-reviews-82x__header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <h2 class="{{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <!-- Rating summary + breakdown bars -->
    {%- if section.settings.show_summary -%}
      <div class="customer-reviews-82x__summary{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <div class="customer-reviews-82x__overall">
          <p class="customer-reviews-82x__avg">{{ section.settings.avg_rating }}</p>
          <p class="customer-reviews-82x__avg-stars" aria-hidden="true">★★★★★</p>
          <p class="customer-reviews-82x__avg-total">{{ section.settings.total_reviews }} {{ 'general.accessibility.reviews' | t | default: 'reviews' }}</p>
        </div>
        <div class="customer-reviews-82x__bars" aria-hidden="true">
          {%- assign stars  = '5,4,3,2,1' | split: ',' -%}
          {%- assign pcts   = section.settings.pct_5
                              | append: ','
                              | append: section.settings.pct_4
                              | append: ','
                              | append: section.settings.pct_3
                              | append: ','
                              | append: section.settings.pct_2
                              | append: ','
                              | append: section.settings.pct_1
                              | split: ',' -%}
          {%- for star in stars -%}
            {%- assign pct = pcts[forloop.index0] | plus: 0 -%}
            <div class="customer-reviews-82x__bar-row">
              <span>{{ star }}★</span>
              <div class="customer-reviews-82x__bar-track">
                <div class="customer-reviews-82x__bar-fill" style="width: {{ pct }}%;"></div>
              </div>
              <span>{{ pct }}%</span>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <!-- Review cards -->
    {%- if review_blocks.size > 0 -%}
      <div
        class="customer-reviews-82x__list{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}
      >
        {%- for block in review_blocks -%}
          <article
            class="customer-reviews-82x__card{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}style="--animation-order: {{ forloop.index }};"{% endif %}
          >
            <div class="customer-reviews-82x__card-header">
              <div class="customer-reviews-82x__avatar" aria-hidden="true">
                {%- if block.settings.avatar != blank -%}
                  {{
                    block.settings.avatar
                    | image_url: width: 96
                    | image_tag:
                      widths: '48, 96',
                      sizes: '4.8rem',
                      loading: 'lazy',
                      alt: ''
                  }}
                {%- endif -%}
              </div>
              <div>
                {%- if block.settings.reviewer_name != blank -%}
                  <p class="customer-reviews-82x__reviewer-name">{{ block.settings.reviewer_name | escape }}</p>
                {%- endif -%}
                {%- if block.settings.reviewer_location != blank -%}
                  <p class="customer-reviews-82x__reviewer-meta">{{ block.settings.reviewer_location | escape }}</p>
                {%- endif -%}
              </div>
            </div>

            <div
              class="customer-reviews-82x__card-stars"
              aria-label="{{ block.settings.rating }} {{ 'general.accessibility.star_reviews_info' | t | default: 'out of 5 stars' }}"
              role="img"
            >
              {%- for i in (1..block.settings.rating) -%}★{%- endfor -%}
            </div>

            {%- if block.settings.review_title != blank -%}
              <p class="customer-reviews-82x__card-title">{{ block.settings.review_title | escape }}</p>
            {%- endif -%}

            {%- if block.settings.review_body != blank -%}
              <div class="customer-reviews-82x__card-body rte">{{ block.settings.review_body }}</div>
            {%- endif -%}

            {%- if block.settings.verified -%}
              <p class="customer-reviews-82x__badge">
                <span aria-hidden="true">✓</span>
                {{- 'general.accessibility.verified_purchase' | t | default: 'Verified Purchase' -}}
              </p>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <!-- CTA -->
    {%- if section.settings.button_label != blank -%}
      <div class="customer-reviews-82x__cta{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="button{% if section.settings.button_style_secondary %} button--secondary{% else %} button--primary{% endif %}"
        >
          {{- section.settings.button_label | escape -}}
        </a>
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "82X Customer Reviews",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Customer's Review"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "header",
      "content": "Rating summary"
    },
    {
      "type": "checkbox",
      "id": "show_summary",
      "label": "Show rating breakdown",
      "default": true
    },
    {
      "type": "text",
      "id": "avg_rating",
      "label": "Average rating (display)",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "total_reviews",
      "label": "Total review count",
      "default": "45,893"
    },
    {
      "type": "range",
      "id": "pct_5",
      "min": 0, "max": 100, "step": 1,
      "label": "5★ percentage",
      "default": 89
    },
    {
      "type": "range",
      "id": "pct_4",
      "min": 0, "max": 100, "step": 1,
      "label": "4★ percentage",
      "default": 7
    },
    {
      "type": "range",
      "id": "pct_3",
      "min": 0, "max": 100, "step": 1,
      "label": "3★ percentage",
      "default": 2
    },
    {
      "type": "range",
      "id": "pct_2",
      "min": 0, "max": 100, "step": 1,
      "label": "2★ percentage",
      "default": 1
    },
    {
      "type": "range",
      "id": "pct_1",
      "min": 0, "max": 100, "step": 1,
      "label": "1★ percentage",
      "default": 1
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "See More Reviews"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary",
      "label": "Use outline button style",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Top padding",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Bottom padding",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Customer photo (optional)"
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer name",
          "default": "Yuki T."
        },
        {
          "type": "text",
          "id": "reviewer_location",
          "label": "Location (optional)",
          "placeholder": "Tokyo, Japan"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1, "max": 5, "step": 1,
          "label": "Star rating",
          "default": 5
        },
        {
          "type": "text",
          "id": "review_title",
          "label": "Review title",
          "default": "Amazing results in just 3 weeks!"
        },
        {
          "type": "richtext",
          "id": "review_body",
          "label": "Review text",
          "default": "<p>I've been using 82X for a month now and my skin has never felt more hydrated and firm. The taste is pleasant and I love that it's from Japan.</p>"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show 'Verified Purchase' badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "82X Customer Reviews",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
