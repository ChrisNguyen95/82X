{{- 'component-slider.css' | asset_url | stylesheet_tag -}}

{%- liquid
  assign is_grid      = false
  if section.settings.desktop_layout == 'grid'
    assign is_grid = true
  endif
  assign cols         = section.settings.desktop_cols | default: 3
  assign cols_minus_1 = cols | minus: 1
-%}

{%- style -%}
/* ════════════════════════════════════════════════════════
   Testimonial Slider — #TestimonialSlider-{{ section.id }}
   ════════════════════════════════════════════════════════ */

/* ── CSS Variables ── */
#TestimonialSlider-{{ section.id }} {
  --ts-gap-desktop:  {{ section.settings.card_gap_desktop }}px;
  --ts-gap-mobile:   {{ section.settings.card_gap_mobile }}px;
  --ts-peek-mobile:  {{ section.settings.card_peek_mobile }}px;
  --ts-radius:       {{ section.settings.card_radius }}px;
  --ts-border-color: {{ section.settings.card_border_color }};
  --ts-border-w:     {{ section.settings.card_border_width }}px;
  --ts-img-radius:   {{ section.settings.card_image_radius }}px;

  background-color: {{ section.settings.background_color }};
  padding-top:    {{ section.settings.padding_top    | times: 0.54 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.54 | round: 0 }}px;
}
@media screen and (min-width: 750px) {
  #TestimonialSlider-{{ section.id }} {
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
}

/* ── Section heading — spacing handled by section-heading.css ── */

/* ════════════════════════════════════════════════════════
   OUTER
   ════════════════════════════════════════════════════════ */
#TestimonialSlider-{{ section.id }} .ts-outer {
  width: 100%;
  overflow: hidden;
}
@media screen and (min-width: 990px) {
  #TestimonialSlider-{{ section.id }} .ts-outer {
    max-width: {{ settings.page_width }}px;
    margin: 0 auto;
    padding-inline: 5rem;
    overflow: visible;
    box-sizing: border-box;
  }
}

/* ════════════════════════════════════════════════════════
   TRACK — SLIDER (default)
   ════════════════════════════════════════════════════════ */
#TestimonialSlider-{{ section.id }} .ts-track {
  display: flex;
  flex-wrap: nowrap;
  list-style: none;
  margin: 0;
  padding: 0.4rem 0 1.2rem;
  overflow-x: scroll;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  -ms-overflow-style: none;
  gap: var(--ts-gap-mobile);
}
#TestimonialSlider-{{ section.id }} .ts-track::-webkit-scrollbar { display: none; }

@media screen and (min-width: 990px) {
  #TestimonialSlider-{{ section.id }} .ts-track {
    gap: var(--ts-gap-desktop);
  }
}

/* ════════════════════════════════════════════════════════
   TRACK — GRID mode (desktop only)
   ════════════════════════════════════════════════════════ */
@media screen and (min-width: 990px) {
  #TestimonialSlider-{{ section.id }} .ts-track--grid {
    flex-wrap: wrap;
    overflow: visible;
    scroll-snap-type: none;
    padding-bottom: 0;
  }
}

/* ════════════════════════════════════════════════════════
   SLIDE ITEM
   ════════════════════════════════════════════════════════ */
#TestimonialSlider-{{ section.id }} .ts-item {
  flex: 0 0 calc(100% - 2 * var(--ts-peek-mobile));
  max-width: calc(100% - 2 * var(--ts-peek-mobile));
  min-width: 0;
  scroll-snap-align: center;
  transition: opacity 0.15s ease;
}

/* ── Desktop: slider N cols ── */
@media screen and (min-width: 990px) {
  #TestimonialSlider-{{ section.id }} .ts-track:not(.ts-track--grid) .ts-item {
    flex: 0 0 calc((100% - {{ cols_minus_1 }} * var(--ts-gap-desktop)) / {{ cols }});
    max-width: calc((100% - {{ cols_minus_1 }} * var(--ts-gap-desktop)) / {{ cols }});
    scroll-snap-align: start;
  }
}

/* ── Desktop: grid N cols ── */
@media screen and (min-width: 990px) {
  #TestimonialSlider-{{ section.id }} .ts-track--grid .ts-item {
    flex: 0 0 calc((100% - {{ cols_minus_1 }} * var(--ts-gap-desktop)) / {{ cols }});
    max-width: calc((100% - {{ cols_minus_1 }} * var(--ts-gap-desktop)) / {{ cols }});
    scroll-snap-align: none;
  }
  /* Hide loop clones in grid mode — clones still exist for mobile slider peek */
  #TestimonialSlider-{{ section.id }} .ts-track--grid .ts-item--clone {
    display: none;
  }
}

/* ════════════════════════════════════════════════════════
   CARD
   ════════════════════════════════════════════════════════ */
#TestimonialSlider-{{ section.id }} .ts-card {
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
  height: 100%;
  padding: {{ section.settings.card_padding }}px 2.4rem;
  text-align: {{ section.settings.card_text_align }};

  border: var(--ts-border-w) solid var(--ts-border-color);
  border-radius: var(--ts-radius);
  background-color: {{ section.settings.card_bg }};
  box-sizing: border-box;
  overflow: hidden;
}

/* ── No-padding option (image-flush) ── */
#TestimonialSlider-{{ section.id }} .ts-card--flush {
  padding: 0;
}
#TestimonialSlider-{{ section.id }} .ts-card--flush .ts-card-body {
  padding: {{ section.settings.card_padding }}px;
}

/* ════════════════════════════════════════════════════════
   CARD IMAGE
   ════════════════════════════════════════════════════════ */
#TestimonialSlider-{{ section.id }} .ts-card-img-wrap {
  width: 100%;
  overflow: hidden;
  flex-shrink: 0;
  {%- if section.settings.card_image_radius > 0 and section.settings.card_image_flush == false -%}
    border-radius: var(--ts-img-radius);
  {%- endif -%}
}

/* Flush image: radius only on top corners */
#TestimonialSlider-{{ section.id }} .ts-card--flush .ts-card-img-wrap {
  border-radius: 0;
}

#TestimonialSlider-{{ section.id }} .ts-card-img {
  width: 100%;
  display: block;
  object-fit: cover;
  {%- if section.settings.card_image_ratio == 'natural' -%}
    height: auto;
  {%- elsif section.settings.card_image_ratio == '1/1' -%}
    aspect-ratio: 1 / 1;
  {%- elsif section.settings.card_image_ratio == '4/3' -%}
    aspect-ratio: 4 / 3;
  {%- elsif section.settings.card_image_ratio == '3/4' -%}
    aspect-ratio: 3 / 4;
  {%- elsif section.settings.card_image_ratio == '16/9' -%}
    aspect-ratio: 16 / 9;
  {%- endif -%}
}

/* Non-flush: image radius follows card_image_radius */
#TestimonialSlider-{{ section.id }} .ts-card:not(.ts-card--flush) .ts-card-img {
  border-radius: var(--ts-img-radius);
}

/* ════════════════════════════════════════════════════════
   CARD BODY (used in flush mode as padding wrapper)
   ════════════════════════════════════════════════════════ */
#TestimonialSlider-{{ section.id }} .ts-card-body {
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
  flex: 1;
}

/* ── Stars ── */
#TestimonialSlider-{{ section.id }} .ts-stars {
  display: flex;
  gap: 0.2rem;
  line-height: 1;
  flex-shrink: 0;
  justify-content: {{ section.settings.card_text_align | replace: 'left', 'flex-start' | replace: 'right', 'flex-end' | replace: 'center', 'center' }};
}
#TestimonialSlider-{{ section.id }} .ts-star {
  font-size: 2rem;
  color: {{ section.settings.star_color_empty }};
}
#TestimonialSlider-{{ section.id }} .ts-star--filled {
  color: {{ section.settings.star_color }};
}

/* ── Author ── */
#TestimonialSlider-{{ section.id }} .ts-author {
  margin: 0;
  font-size: 2rem;
  font-weight: 600;
  line-height: 1.3;
  color: {{ section.settings.author_color }};
}

/* ── Review text ── */
#TestimonialSlider-{{ section.id }} .ts-text {
  margin: 0;
  font-size: 1.4rem;
  line-height: 1.7;
  color: {{ section.settings.review_text_color }};
  flex: 1;
}

/* ── Nav ── */
#TestimonialSlider-{{ section.id }} .custom-slider-nav {
  --csn-color: {{ section.settings.nav_color }};
  margin-top: 3.2rem;
}
/* Hide nav on desktop in grid mode — keep in DOM for loop JS */
@media screen and (min-width: 990px) {
  #TestimonialSlider-{{ section.id }} .ts-nav--grid-hidden {
    display: none;
  }
  #TestimonialSlider-{{ section.id }} .custom-slider-nav {
  margin-top: 4rem;
}
}
/* Hide nav when show_nav setting is off — keep in DOM for loop JS */
#TestimonialSlider-{{ section.id }} .ts-nav--hidden {
  visibility: hidden;
  pointer-events: none;
  height: 0;
  overflow: hidden;
  margin: 0;
}

/* ── Footer button ── */
#TestimonialSlider-{{ section.id }} .ts-footer {
  text-align: center;
  padding-top: {{ section.settings.footer_gap | times: 0.8 }}px;
}
@media screen and (min-width: 990px) {
  #TestimonialSlider-{{ section.id }} .ts-footer {
    padding-top: {{ section.settings.footer_gap }}px;
  }
}
{%- endstyle -%}

{%- if section.blocks.size > 0 -%}
<section
  id="TestimonialSlider-{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} gradient{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
>

  {%- comment -%}── Heading ──{%- endcomment -%}
  <div class="page-width">
    {%- render 'section-heading',
      heading:        section.settings.heading,
      heading_tag:    section.settings.heading_tag,
      heading_size:   section.settings.heading_size,
      heading_align:  section.settings.heading_align,
      heading_italic: section.settings.heading_italic,
      subheading:     section.settings.subheading,
      description:    section.settings.description
    -%}
  </div>

  {%- comment -%}── Slider / Grid track ──{%- endcomment -%}
  <div class="ts-outer">
    <ul
      id="ts-track-{{ section.id }}"
      class="ts-track{% if is_grid %} ts-track--grid{% endif %}"
      role="list"
      aria-label="{{ section.settings.heading | escape }}"
    >
      {%- for block in section.blocks -%}
        {%- assign star_count  = block.settings.star_rating | default: 5 -%}
        {%- assign has_image   = false -%}
        {%- if block.settings.image != blank -%}
          {%- assign has_image = true -%}
        {%- endif -%}
        {%- assign flush_img = false -%}
        {%- if has_image and section.settings.card_image_flush -%}
          {%- assign flush_img = true -%}
        {%- endif -%}

        <li
          id="ts-item-{{ section.id }}-{{ forloop.index }}"
          class="ts-item{% if settings.animations_reveal_on_scroll and is_grid %} scroll-trigger animate--slide-in{% endif %}"
          role="listitem"
          data-real-index="{{ forloop.index0 }}"
          {% if settings.animations_reveal_on_scroll and is_grid %}style="--animation-order: {{ forloop.index }};"{% endif %}
          {{ block.shopify_attributes }}
        >
          <div class="ts-card{% if flush_img %} ts-card--flush{% endif %}">

            {%- comment -%}── Reviewer image ──{%- endcomment -%}
            {%- if has_image -%}
              <div class="ts-card-img-wrap">
                {{
                  block.settings.image
                  | image_url: width: 800
                  | image_tag:
                    class: 'ts-card-img',
                    loading: 'lazy',
                    widths: '400, 600, 800',
                    alt: block.settings.author | escape
                }}
              </div>
            {%- endif -%}

            {%- comment -%}── Card body ──{%- endcomment -%}
            <div class="ts-card-body">

              {%- comment -%}── Stars ──{%- endcomment -%}
              {%- if section.settings.show_stars -%}
                <div class="ts-stars" role="img" aria-label="{{ star_count }} out of 5 stars">
                  {%- for i in (1..5) -%}
                    <span class="ts-star{% if i <= star_count %} ts-star--filled{% endif %}" aria-hidden="true">★</span>
                  {%- endfor -%}
                </div>
              {%- endif -%}

              {%- comment -%}── Author ──{%- endcomment -%}
              {%- if block.settings.author != blank -%}
                <p class="ts-author font-heading">
                  {{- block.settings.author | escape -}}
                  {%- if block.settings.location != blank -%}
                    <span aria-hidden="true"> · </span>{{ block.settings.location | escape }}
                  {%- endif -%}
                </p>
              {%- endif -%}

              {%- comment -%}── Review text ──{%- endcomment -%}
              {%- if block.settings.text != blank -%}
                <p class="ts-text">{{ block.settings.text | escape }}</p>
              {%- endif -%}

            </div>{%- comment -%}/.ts-card-body{%- endcomment -%}
          </div>{%- comment -%}/.ts-card{%- endcomment -%}
        </li>
      {%- endfor -%}
    </ul>
  </div>

 
  {%- comment -%}── Navigation — always in DOM so loop JS can find prevEl/nextEl ──{%- endcomment -%}
  {%- assign nav_hidden_class = '' -%}
  {%- if is_grid -%}{%- assign nav_hidden_class = ' ts-nav--grid-hidden' -%}{%- endif -%}
  {%- unless section.settings.show_nav -%}{%- assign nav_hidden_class = ' ts-nav--hidden' -%}{%- endunless -%}
  <div class="page-width{{ nav_hidden_class }}">
    {%- render 'slider-nav-buttons',
      section_id: section.id,
      id_prefix:  'ts'
    -%}
  </div>


  {%- comment -%}── Footer button ──{%- endcomment -%}
  {%- if section.settings.button_label != blank -%}
    <div class="page-width">
      <div class="ts-footer">
        <a
          href="{{ section.settings.button_link | default: '#' }}"
          class="button{% if section.settings.button_secondary %} button--secondary{% else %} button--primary{% endif %}"
        >
          {{- section.settings.button_label | escape -}}
        </a>
      </div>
    </div>
  {%- endif -%}

</section>

{%- comment -%}── Slider loop JS — always rendered (mobile always needs peek/loop) ──{%- endcomment -%}
{%- assign _track_id = 'ts-track-' | append: section.id -%}
{%- assign _prev_id  = 'ts-prev-'  | append: section.id -%}
{%- assign _next_id  = 'ts-next-'  | append: section.id -%}
{%- render 'slider-loop-js',
  track_id:      _track_id,
  prev_id:       _prev_id,
  next_id:       _next_id,
  loop_enabled:  section.settings.loop_enabled,
  snap_center:   true,
  item_selector: '.ts-item',
  clone_class:   'ts-item--clone'
-%}

{%- endif -%}

{% schema %}
{
  "name": "Testimonial Slider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Quality Ingredients Lead To Happy Customers."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2",  "label": "Small" },
        { "value": "h1",  "label": "Medium" },
        { "value": "h0",  "label": "Large" },
        { "value": "hxl", "label": "Extra large" }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading HTML tag",
      "options": [
        { "value": "h1", "label": "h1" },
        { "value": "h2", "label": "h2" },
        { "value": "h3", "label": "h3" },
        { "value": "p",  "label": "p"  }
      ],
      "default": "h2"
    },
    {
      "type": "checkbox",
      "id": "heading_italic",
      "label": "Italic heading",
      "default": false
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Desktop layout",
      "options": [
        { "value": "slider", "label": "Slider (scroll)" },
        { "value": "grid",   "label": "Grid (all visible)" }
      ],
      "default": "slider",
      "info": "Mobile is always a slider regardless of this setting."
    },
    {
      "type": "select",
      "id": "desktop_cols",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "3"
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Border color",
      "default": "#E0E0E0"
    },
    {
      "type": "range",
      "id": "card_border_width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "Border width",
      "info": "Set to 0 to remove border completely.",
      "default": 0
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Card corner radius",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Card padding",
      "default": 24
    },
    {
      "type": "select",
      "id": "card_text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Card — Image"
    },
    {
      "type": "select",
      "id": "card_image_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "natural", "label": "Natural (no crop)" },
        { "value": "1/1",     "label": "Square (1:1)" },
        { "value": "4/3",     "label": "Landscape (4:3)" },
        { "value": "3/4",     "label": "Portrait (3:4)" },
        { "value": "16/9",    "label": "Wide (16:9)" }
      ],
      "default": "3/4"
    },
    {
      "type": "range",
      "id": "card_image_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image corner radius",
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "card_image_flush",
      "label": "Flush image (image edge-to-edge, no padding around image)",
      "default": false
    },
    {
      "type": "header",
      "content": "Card — Text colors"
    },
    {
      "type": "color",
      "id": "author_color",
      "label": "Author name color",
      "default": "#1C2B6B"
    },
    {
      "type": "color",
      "id": "review_text_color",
      "label": "Review text color",
      "default": "#3D3D3D"
    },
    {
      "type": "header",
      "content": "Stars"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show stars",
      "default": true
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Filled star color",
      "default": "#F5A623"
    },
    {
      "type": "color",
      "id": "star_color_empty",
      "label": "Empty star color",
      "default": "#D4D4D4"
    },
    {
      "type": "header",
      "content": "Footer button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "placeholder": "e.g. READ ALL REVIEWS"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "button_secondary",
      "label": "Outline style",
      "default": false
    },
    {
      "type": "range",
      "id": "footer_gap",
      "min": 16,
      "max": 80,
      "step": 8,
      "unit": "px",
      "label": "Gap above button",
      "default": 40
    },
    {
      "type": "header",
      "content": "Spacing — Mobile"
    },
    {
      "type": "range",
      "id": "card_peek_mobile",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "label": "Peek size (each side)",
      "default": 32
    },
    {
      "type": "range",
      "id": "card_gap_mobile",
      "min": 4,
      "max": 32,
      "step": 4,
      "unit": "px",
      "label": "Gap between cards",
      "default": 12
    },
    {
      "type": "header",
      "content": "Spacing — Desktop"
    },
    {
      "type": "range",
      "id": "card_gap_desktop",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Gap between cards",
      "default": 24
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "checkbox",
      "id": "show_nav",
      "label": "Show prev / next buttons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop_enabled",
      "label": "Enable infinite loop",
      "default": true
    },
    {
      "type": "color",
      "id": "nav_color",
      "label": "Nav button color",
      "default": "#1C2B6B"
    },
    {
      "type": "header",
      "content": "Section style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
