            "author": "Lisa Nguyen",
            "location": "California, USA",
            "star_rating": 5,
            "text": "I started using 82X Sakura Collagen to improve my skin and balance my hormones, and I was really impressed after just one bottle."
          }
        },
        {
          "type": "review",
          "settings": {
            "author": "Rachel Thompson",
            "location": "New York, USA",
            "star_rating": 5,
            "text": "I've tried many collagen brands, but Sakura Collagen stands out. My skin feels smooth, and my nails are growing stronger too!"
          }
        }
      ]
    }
  ]
}
{% endschema %}
