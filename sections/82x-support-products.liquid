{{ 'brand-sections.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="support-products-82x color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">

    <div class="support-products-82x__header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {%- if section.settings.subheading != blank -%}
        <p class="caption-with-letter-spacing">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="support-products-82x__heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div
      class="support-products-82x__list{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
      {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}
    >
      {%- for block in section.blocks -%}

        <div
          class="support-products-82x__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {{ block.shopify_attributes }}
          {% if settings.animations_reveal_on_scroll %}style="--animation-order: {{ forloop.index }};"{% endif %}
        >
          <!-- Product image -->
          <div class="support-products-82x__image-wrap">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 480
                | image_tag:
                  widths: '120, 200, 280, 360, 480',
                  sizes: '(min-width: 990px) 24rem, (min-width: 750px) 18rem, 12rem',
                  loading: 'lazy',
                  alt: block.settings.product_name | default: ''
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>

          <!-- Product info -->
          <div class="support-products-82x__info">
            {%- if block.settings.product_name != blank -%}
              <p class="support-products-82x__name">{{ block.settings.product_name | escape }}</p>
            {%- endif -%}

            {%- if block.settings.benefits != blank -%}
              {%- assign benefit_lines = block.settings.benefits | newline_to_br | split: '<br />' -%}
              <ul class="support-products-82x__benefits" role="list">
                {%- for line in benefit_lines -%}
                  {%- assign trimmed = line | strip | strip_html -%}
                  {%- if trimmed != blank -%}
                    <li class="support-products-82x__benefit">{{ trimmed | escape }}</li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}

            {%- if block.settings.button_label != blank -%}
              <a
                href="{{ block.settings.button_link | default: '#' }}"
                class="button button--secondary"
              >
                {{- block.settings.button_label | escape -}}
              </a>
            {%- endif -%}
          </div>
        </div>

        {%- unless forloop.last -%}
          <hr class="support-products-82x__divider" aria-hidden="true">
        {%- endunless -%}

      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "82X Support Products",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Eyebrow text"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "3 Parts To Our Maximum Support"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Top padding",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Bottom padding",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Product name",
          "default": "82X Sakura Placenta – White & Contour"
        },
        {
          "type": "textarea",
          "id": "benefits",
          "label": "Benefits list (one per line)",
          "default": "Brightens and evens skin tone\nReduces fine lines and wrinkles\nBoosts collagen synthesis naturally\nSupports skin elasticity and firmness"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "82X Support Products",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
