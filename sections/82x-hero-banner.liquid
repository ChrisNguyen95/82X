{{ 'brand-sections.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  {%- if section.settings.bg_color != 'rgba(0,0,0,0)' and section.settings.bg_color != blank -%}
    .hero-82x-{{ section.id }} { background-color: {{ section.settings.bg_color }}; }
  {%- endif -%}
{%- endstyle -%}

{%- liquid
  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
  assign trust_blocks = section.blocks | where: 'type', 'trust_badge'
-%}

<div class="hero-82x hero-82x-{{ section.id }} color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    <div
      class="hero-82x__grid hero-82x__grid--{{ section.settings.layout }} hero-82x__grid--mobile_{{ section.settings.mobile_layout }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    >

      <!-- Content column -->
      <div class="hero-82x__content">
        {%- if section.settings.subheading != blank -%}
          <p class="hero-82x__eyebrow">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="hero-82x__heading {{ section.settings.heading_size }}">
            {{- section.settings.heading -}}
          </h1>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="hero-82x__text rte">{{ section.settings.text }}</div>
        {%- endif -%}

        <div class="hero-82x__buttons">
          {%- if section.settings.button_label != blank -%}
            <a
              href="{{ section.settings.button_link | default: '#' }}"
              class="button button--primary"
            >
              {{- section.settings.button_label | escape -}}
            </a>
          {%- endif -%}

          {%- if section.settings.button_label_2 != blank -%}
            <a
              href="{{ section.settings.button_link_2 | default: '#' }}"
              class="button button--secondary"
            >
              {{- section.settings.button_label_2 | escape -}}
            </a>
          {%- endif -%}
        </div>

        {%- if trust_blocks.size > 0 -%}
          <ul class="hero-82x__trust list-unstyled" role="list">
            {%- for block in trust_blocks -%}
              <li class="hero-82x__trust-item" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <span class="hero-82x__trust-icon">
                    {{-
                      block.settings.icon
                      | image_url: width: 40
                      | image_tag:
                        loading: 'lazy',
                        widths: '20, 40',
                        alt: block.settings.label | default: ''
                    -}}
                  </span>
                {%- endif -%}
                {%- if block.settings.label != blank -%}
                  <span class="hero-82x__trust-label">{{ block.settings.label | escape }}</span>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <!-- Image column -->
      {%- if section.settings.image != blank -%}
        <div class="hero-82x__media">
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              widths: '400, 600, 800, 1000, 1200',
              sizes: '(min-width: 990px) 48vw, 90vw',
              loading: 'eager',
              fetchpriority: fetch_priority,
              class: 'hero-82x__image small-hide medium-hide'
          }}
          {%- if section.settings.image_mobile != blank -%}
            {{
              section.settings.image_mobile
              | image_url: width: 800
              | image_tag:
                widths: '400, 600, 800',
                sizes: '90vw',
                loading: 'eager',
                fetchpriority: fetch_priority,
                class: 'hero-82x__image large-up-hide'
            }}
          {%- else -%}
            {{
              section.settings.image
              | image_url: width: 800
              | image_tag:
                widths: '400, 600, 800',
                sizes: '90vw',
                loading: 'eager',
                fetchpriority: fetch_priority,
                class: 'hero-82x__image large-up-hide'
            }}
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "82X Hero Banner",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Eyebrow text",
      "default": "Premium Japanese Collagen"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Reveal Your Natural Glow — Just $5 Per Day"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra large" }
      ],
      "default": "h0"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body text",
      "default": "<p>Japan's #1 liquid collagen drink. Clinically formulated with marine collagen and Sakura Placenta for radiant, youthful skin from within.</p>"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Hero image (mobile) — optional, falls back to desktop"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Image side (desktop)",
      "options": [
        { "value": "image_right", "label": "Image right" },
        { "value": "image_left", "label": "Image left" }
      ],
      "default": "image_right"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Image position (mobile)",
      "options": [
        { "value": "image_below", "label": "Below text" },
        { "value": "image_above", "label": "Above text" }
      ],
      "default": "image_below"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color override",
      "info": "Overrides the color scheme background for this section only"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label text",
          "default": "Free Shipping"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "82X Hero Banner",
      "blocks": [
        { "type": "trust_badge", "settings": { "label": "Free Shipping" } },
        { "type": "trust_badge", "settings": { "label": "Money Back Guarantee" } },
        { "type": "trust_badge", "settings": { "label": "5-Star Rated" } }
      ]
    }
  ]
}
{% endschema %}
