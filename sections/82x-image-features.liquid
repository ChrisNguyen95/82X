{%- style -%}
  /* ══════════════════════════════════════════
     82X Image + Features  (#IWTFeatures-ID)
  ══════════════════════════════════════════ */

  /* ── Section padding ── */
  #IWTFeatures-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #IWTFeatures-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ── Grid ── */
  #IWTFeatures-{{ section.id }} .iwtf-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media screen and (min-width: 990px) {
    #IWTFeatures-{{ section.id }} .iwtf-grid {
      grid-template-columns: 9fr 11fr;
      gap: 8rem;
    }
    {%- if section.settings.image_position == 'left' -%}
      #IWTFeatures-{{ section.id }} .iwtf-media  { order: 1; }
      #IWTFeatures-{{ section.id }} .iwtf-content { order: 2; }
    {%- else -%}
      #IWTFeatures-{{ section.id }} .iwtf-media  { order: 2; }
      #IWTFeatures-{{ section.id }} .iwtf-content { order: 1; }
    {%- endif -%}
  }

  /* ── Image ── */
  #IWTFeatures-{{ section.id }} .iwtf-media {
    border-radius: 1.2rem;
    overflow: hidden;
    min-height: 32rem;
  }
  #IWTFeatures-{{ section.id }} .iwtf-media img,
  #IWTFeatures-{{ section.id }} .iwtf-media .placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
  @media screen and (min-width: 990px) {
    #IWTFeatures-{{ section.id }} .iwtf-media {
      min-height: 52rem;
    }
  }

  /* ── Content column — consistent block spacing ── */
  #IWTFeatures-{{ section.id }} .iwtf-content > * + * {
    margin-top: 2.8rem;
  }
  #IWTFeatures-{{ section.id }} .iwtf-heading + .iwtf-text,
  #IWTFeatures-{{ section.id }} .iwtf-heading + .iwtf-row {
    margin-top: 1.6rem;
  }
  #IWTFeatures-{{ section.id }} .iwtf-row + .iwtf-row {
    margin-top: 2.4rem;
  }
  #IWTFeatures-{{ section.id }} .iwtf-row + .iwtf-certified,
  #IWTFeatures-{{ section.id }} .iwtf-text + .iwtf-certified {
    margin-top: 3.2rem;
  }

  /* ── Heading ── */
  #IWTFeatures-{{ section.id }} .iwtf-heading {
    margin: 0;
  }

  /* ── Text ── */
  #IWTFeatures-{{ section.id }} .iwtf-text {
    font-size: 1.5rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.75);
    margin: 0;
  }
  #IWTFeatures-{{ section.id }} .iwtf-text p { margin: 0; }

  /* ── Content row ── */
  #IWTFeatures-{{ section.id }} .iwtf-row {
    display: flex;
    align-items: flex-start;
    gap: 1.6rem;
  }
  #IWTFeatures-{{ section.id }} .iwtf-row__icon-wrap {
    flex-shrink: 0;
    width: 4.8rem;
    height: 4.8rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  #IWTFeatures-{{ section.id }} .iwtf-row__icon-wrap img {
    width: 2.4rem;
    height: 2.4rem;
    object-fit: contain;
    display: block;
  }
  #IWTFeatures-{{ section.id }} .iwtf-row__body {
    flex: 1;
    min-width: 0;
    padding-top: 0.4rem;
  }
  #IWTFeatures-{{ section.id }} .iwtf-row__heading {
    font-size: 2rem;
    font-weight: 600;
    margin: 0 0 0.6rem;
    line-height: 1.3;
    letter-spacing: 0.02em;
    color: rgba(var(--color-foreground), 0.95);
  }
  #IWTFeatures-{{ section.id }} .iwtf-row__text {
    font-size: 1.4rem;
    line-height: 1.65;
    color: rgba(var(--color-foreground), 0.65);
    margin: 0;
  }

  /* ── Certified card ── */
  #IWTFeatures-{{ section.id }} .iwtf-certified {
    display: flex;
    align-items: center;
    gap: 2rem;
    border-top: 0.1rem solid rgba(var(--color-foreground), 0.12);
    padding: 1.2rem 0;
  }
  
  @media screen and (min-width: 990px) {
      #IWTFeatures-{{ section.id }} .iwtf-certified {
        gap: 3.6rem;
      }

      #IWTFeatures-{{ section.id }} .iwtf-row + .iwtf-certified,
      #IWTFeatures-{{ section.id }} .iwtf-text + .iwtf-certified {
        margin-top: 6.2rem;
      }

  }
  #IWTFeatures-{{ section.id }} .iwtf-certified__left {
    display: flex;
    align-items: flex-start;
    gap: 1.4rem;
    flex: 1;
    min-width: 0;
  }
  #IWTFeatures-{{ section.id }} .iwtf-certified__logo {
    flex-shrink: 0;
    width: 5.6rem;
    height: 5.6rem;
    border-radius: 50%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--color-foreground), 0.06);
  }
  #IWTFeatures-{{ section.id }} .iwtf-certified__logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #IWTFeatures-{{ section.id }} .iwtf-certified__info {
    flex: 1;
    min-width: 0;
  }
  #IWTFeatures-{{ section.id }} .iwtf-certified__title {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0 0 0.6rem;
    color: rgba(var(--color-foreground), 0.95);
  }
  #IWTFeatures-{{ section.id }} .iwtf-certified__desc {
    font-size: 1.4rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0;
  }
  #IWTFeatures-{{ section.id }} .iwtf-certified__desc p { margin: 0; }

  /* ── Score box ── */
  #IWTFeatures-{{ section.id }} .iwtf-certified__score {
    flex-shrink: 0;
    border-radius: 1rem;
    padding: 1.6rem 2.4rem;
    text-align: center;
    min-width: 12rem;
  }
  #IWTFeatures-{{ section.id }} .iwtf-certified__score-label {
    font-size: 1.15rem;
    font-weight: 600;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0 0 0.4rem;
    line-height: 1.3;
  }
  #IWTFeatures-{{ section.id }} .iwtf-certified__score-value {
    font-size: 3.8rem;
    font-weight: 800;
    font-family: var(--font-heading-family);
    line-height: 1;
    margin: 0 0 0.5rem;
    color: rgba(var(--color-foreground), 0.95);
  }
  #IWTFeatures-{{ section.id }} .iwtf-certified__score-sub {
    font-size: 1.1rem;
    color: rgba(var(--color-foreground), 0.5);
    margin: 0;
  }

  /* ── Mobile adjustments ── */
  @media screen and (max-width: 749px) {
    #IWTFeatures-{{ section.id }} .iwtf-certified {
      flex-direction: column;
      align-items: stretch;
    }
    #IWTFeatures-{{ section.id }} .iwtf-certified__score {
      width: 100%;
      min-width: unset;
    }
    #IWTFeatures-{{ section.id }} .iwtf-row__heading {
      font-size: 1.6rem;
    }
  }
{%- endstyle -%}

<div
  id="IWTFeatures-{{ section.id }}"
  class="gradient color-{{ section.settings.color_scheme }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
>
  {%- unless section.settings.full_width -%}
    <div class="page-width">
  {%- endunless -%}

  <div class="iwtf-grid">

    {%- comment -%}── Image column ──{%- endcomment -%}
    <div class="iwtf-media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800, 1000, 1200',
            sizes: '(min-width: 990px) 55vw, 100vw',
            width: section.settings.image.width,
            height: section.settings.image.height
        }}
      {%- else -%}
        {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

    {%- comment -%}── Content column ──{%- endcomment -%}
    <div class="iwtf-content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'heading' -%}
            <h2
              class="iwtf-heading {{ block.settings.heading_size }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.heading }}
            </h2>

          {%- when 'text' -%}
            <div class="iwtf-text rte" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>

          {%- when 'content_row' -%}
            <div class="iwtf-row" {{ block.shopify_attributes }}>
              <div
                class="iwtf-row__icon-wrap"
                style="background: {{ block.settings.icon_bg_color }};"
              >
                {%- if block.settings.icon != blank -%}
                  <img
                    src="{{ block.settings.icon | image_url: width: 48 }}"
                    width="24"
                    height="24"
                    alt=""
                    loading="lazy"
                  >
                {%- endif -%}
              </div>
              <div class="iwtf-row__body">
                {%- if block.settings.row_heading != blank -%}
                  <p class="iwtf-row__heading">{{ block.settings.row_heading | escape }}</p>
                {%- endif -%}
                {%- if block.settings.row_text != blank -%}
                  <p class="iwtf-row__text">{{ block.settings.row_text | escape }}</p>
                {%- endif -%}
              </div>
            </div>

          {%- when 'certified' -%}
            <div class="iwtf-certified" {{ block.shopify_attributes }}>
              <div class="iwtf-certified__left">
                {%- if block.settings.logo != blank -%}
                  {%- liquid
                    assign cert_logo_alt = block.settings.title | default: shop.name | escape
                  -%}
                  <div class="iwtf-certified__logo">
                    <img
                      src="{{ block.settings.logo | image_url: width: 112 }}"
                      width="56"
                      height="56"
                      alt="{{ cert_logo_alt }}"
                      loading="lazy"
                    >
                  </div>
                {%- endif -%}
                <div class="iwtf-certified__info">
                  {%- if block.settings.title != blank -%}
                    <p class="iwtf-certified__title">{{ block.settings.title | escape }}</p>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <div class="iwtf-certified__desc rte">{{ block.settings.description }}</div>
                  {%- endif -%}
                </div>
              </div>

              {%- if block.settings.score_label != blank or block.settings.score_value != blank -%}
                <div
                  class="iwtf-certified__score"
                  style="background: {{ block.settings.score_bg_color }};"
                >
                  {%- if block.settings.score_label != blank -%}
                    <p class="iwtf-certified__score-label">{{ block.settings.score_label | escape }}</p>
                  {%- endif -%}
                  {%- if block.settings.score_value != blank -%}
                    <p class="iwtf-certified__score-value">{{ block.settings.score_value | escape }}</p>
                  {%- endif -%}
                  {%- if block.settings.score_subtitle != blank -%}
                    <p class="iwtf-certified__score-sub">{{ block.settings.score_subtitle | escape }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>

        {%- endcase -%}
      {%- endfor -%}
    </div>

  </div>

  {%- unless section.settings.full_width -%}
    </div>
  {%- endunless -%}
</div>

{% schema %}
{
  "name": "82X Image + Features",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position (desktop)",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left",  "label": "Left"  }
      ],
      "default": "right"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Why You Can Trust Us"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Size",
          "options": [
            { "value": "h1", "label": "X-Large" },
            { "value": "h2", "label": "Large" },
            { "value": "h3", "label": "Medium" },
            { "value": "h4", "label": "Small" }
          ],
          "default": "h2"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add a supporting description here.</p>"
        }
      ]
    },
    {
      "type": "content_row",
      "name": "Content row",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (SVG or image, 24×24 recommended)"
        },
        {
          "type": "color",
          "id": "icon_bg_color",
          "label": "Icon background color",
          "default": "#EBF3FF"
        },
        {
          "type": "text",
          "id": "row_heading",
          "label": "Heading",
          "default": "Feature title"
        },
        {
          "type": "text",
          "id": "row_text",
          "label": "Description",
          "default": "Short description of this feature or benefit."
        }
      ]
    },
    {
      "type": "certified",
      "name": "Certified badge",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Left — logo & text"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Proud To Be A Certified B Corporation"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Since 2023, we've been part of a global movement of businesses using profit as a force for good.</p>"
        },
        {
          "type": "header",
          "content": "Right — score box"
        },
        {
          "type": "color",
          "id": "score_bg_color",
          "label": "Score box background",
          "default": "#EBF3FF"
        },
        {
          "type": "text",
          "id": "score_label",
          "label": "Label",
          "default": "B Impact Score"
        },
        {
          "type": "text",
          "id": "score_value",
          "label": "Score value",
          "default": "85.4"
        },
        {
          "type": "text",
          "id": "score_subtitle",
          "label": "Subtitle",
          "default": "Above Average"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "82X Image + Features",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "content_row" },
        { "type": "content_row" },
        { "type": "content_row" },
        { "type": "certified" }
      ]
    }
  ]
}
{% endschema %}
