        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap_col",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Column gap",
      "default": 14
    },
    {
      "type": "range",
      "id": "grid_gap_row",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "label": "Row gap",
      "default": 32
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "select",
