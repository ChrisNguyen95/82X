      "id": "excerpt_color",
      "label": "Excerpt color",
      "default": "#6B7280"
    },
    {
      "type": "header",
      "content": "Sidebar"
    },
    {
      "type": "text",
      "id": "sidebar_title",
      "label": "Sidebar title",
      "default": "Shop 82X Favorites"
    },
    {
      "type": "range",
      "id": "sidebar_gap_desktop",
      "min": 40,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Gap sidebar ↔ content (≥1200px)",
