{%- style -%}
  /* ── Padding ── */
  .section-{{ section.id }}-padding {
    padding-top:    {{ section.settings.padding_top    | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top:    {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ══════════════════════════════════════════════
     STRUCTURAL CSS — all inline for Customize reliability
     ══════════════════════════════════════════════ */

  /* ── 2-column layout: sidebar 3fr (min 302px) + content 9fr ── */
  #BlogRows-{{ section.id }} .blr-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: start;
  }
  @media screen and (min-width: 990px) and (max-width: 1199px) {
    #BlogRows-{{ section.id }} .blr-layout {
      grid-template-columns: minmax(30.2rem, 3fr) 9fr;
      gap: {{ section.settings.sidebar_gap_tablet }}rem;
    }
  }
  @media screen and (min-width: 1200px) {
    #BlogRows-{{ section.id }} .blr-layout {
      grid-template-columns: minmax(30.2rem, 3fr) 9fr;
      gap: {{ section.settings.sidebar_gap_desktop }}px;
    }
  }

  /* ════════════════════════════════════════
     SIDEBAR — dynamic values only (structure in 82x-blog.css)
     ════════════════════════════════════════ */
  #BlogRows-{{ section.id }} .blc-sidebar-product__img-wrap {
    border-radius: {{ section.settings.sidebar_img_radius }}px;
    background: {{ section.settings.sidebar_img_bg }};
  }

  /* ════════════════════════════════════════
     BLOG ROWS (right column)
     ════════════════════════════════════════ */
  #BlogRows-{{ section.id }} .blr-content {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.row_gap }}px;
  }

  /* ── Each row ── */
  #BlogRows-{{ section.id }} .blr-row {
    padding-bottom: {{ section.settings.row_gap }}px;
    border-bottom: 0.1rem solid {{ section.settings.border_color }};
  }
  #BlogRows-{{ section.id }} .blr-row:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  /* ── Row header: title left, View All right ── */
  #BlogRows-{{ section.id }} .blr-row__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 3.2rem;
  }
  #BlogRows-{{ section.id }} .blr-row__title {
    font-family: var(--font-heading-family);
    font-weight: 600;
    font-size: 4rem;
    line-height: 1.2;
    color: rgba(var(--color-foreground), 1);
    margin: 0;
  }
  @media screen and (max-width: 749px) {
    #BlogRows-{{ section.id }} .blr-row__title {
      font-size: 2.4rem;
    }
  }
  #BlogRows-{{ section.id }} .blr-row__view-all {
    font-size: 1.4rem;
    font-weight: 500;
    color: {{ section.settings.view_all_color }};
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }
  #BlogRows-{{ section.id }} .blr-row__view-all:hover { opacity: 0.7; }

  /* ── Article grid per row (columns set per-block via ID, see below) ── */
  #BlogRows-{{ section.id }} .blr-grid {
    display: grid;
    column-gap: {{ section.settings.grid_gap_col }}px;
    row-gap:    {{ section.settings.grid_gap_row }}px;
  }

  /* ══════════════════════════════════════════════
     MOBILE OVERRIDES (≤749px)
     ══════════════════════════════════════════════ */
  @media screen and (max-width: 749px) {
    /* Row header: wrap so View All drops below title on narrow screens */
    #BlogRows-{{ section.id }} .blr-row__header {
      flex-wrap: wrap;
      gap: 0.8rem;
      margin-bottom: 2rem;
    }
    /* Card title: scale down for 2-column narrow cards */
    #BlogRows-{{ section.id }} .blc-card__title {
      font-size: 1.5rem;
      letter-spacing: 0.05rem;
    }
    /* Image → content gap: reduce from 2.4rem */
    #BlogRows-{{ section.id }} .blc-card__img-wrap {
      margin-bottom: 1.2rem;
    }
    /* Date meta: tighter gap */
    #BlogRows-{{ section.id }} .blc-card__meta {
      margin-top: 0.4rem;
    }
  }

  /* ════════════════════════════════════════
     ARTICLE CARD — dynamic values only (structure in 82x-blog.css)
     ════════════════════════════════════════ */
  #BlogRows-{{ section.id }} .blc-card__img-wrap {
    aspect-ratio: {{ section.settings.image_ratio }};
    border-radius: {{ section.settings.card_radius }}px;
    background: {{ section.settings.card_img_bg }};
  }
  #BlogRows-{{ section.id }} .blc-card__title {
    color: {{ section.settings.title_color }};
    -webkit-line-clamp: {{ section.settings.title_lines }};
  }
  #BlogRows-{{ section.id }} .blc-card__meta {
    color: {{ section.settings.date_color }};
  }
  #BlogRows-{{ section.id }} .blc-card__excerpt {
    color: {{ section.settings.excerpt_color }};
    -webkit-line-clamp: {{ section.settings.excerpt_lines }};
  }
{%- endstyle -%}

{%- comment -%}── Per-block grid columns — single style tag (one per section, not one per block) ──{%- endcomment -%}
{%- style -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'blog_row' -%}
      #blr-grid-{{ block.id }} {
        grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
      }
      @media screen and (max-width: 749px) {
        #blr-grid-{{ block.id }} {
          grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
        }
      }
    {%- endif -%}
  {%- endfor -%}
{%- endstyle -%}

<section
  id="BlogRows-{{ section.id }}"
  class="section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient"
>
  <div class="page-width">
    <div class="blr-layout">

      {%- comment -%}── Left: Sidebar ──{%- endcomment -%}
      <aside class="blc-sidebar" aria-label="{{ section.settings.sidebar_title | escape }}">
        {%- if section.settings.sidebar_title != blank -%}
          <span class="blc-sidebar__title font-heading">{{ section.settings.sidebar_title | escape }}</span>
        {%- endif -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'product' and block.settings.product != blank -%}
            {%- assign sp = block.settings.product -%}
            <a href="{{ sp.url }}" class="blc-sidebar-product" {{ block.shopify_attributes }}>
              <div class="blc-sidebar-product__img-wrap">
                {%- if sp.featured_image != blank -%}
                  {{
                    sp.featured_image
                    | image_url: width: 160
                    | image_tag:
                      loading: 'lazy',
                      widths: '80, 120, 160',
                      alt: sp.title | escape
                  }}
                {%- endif -%}
              </div>
              <div>
                <span class="blc-sidebar-product__title font-heading">{{ sp.title | escape }}</span>
                {% render 'okendo-reviews-product-rating-summary', product: sp %}
                {% render 'price', product: sp, price_class: '', show_compare_at_price: true %}
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </aside>

      {%- comment -%}── Right: Blog rows ──{%- endcomment -%}
      <div class="blr-content">

        {%- for block in section.blocks -%}
          {%- if block.type == 'blog_row' and block.settings.blog != blank -%}

            {%- assign row_blog    = block.settings.blog -%}
            {%- assign row_cols    = block.settings.columns_desktop -%}
            {%- assign row_heading = block.settings.heading | default: row_blog.title -%}

            <div class="blr-row" {{ block.shopify_attributes }}>

              {%- comment -%}── Row header ──{%- endcomment -%}
              <div class="blr-row__header">
                {%- assign _htag = block.settings.heading_tag | default: 'h2' -%}
                {%- if _htag == 'h3' -%}
                  <h3 class="blr-row__title">{{ row_heading | escape }}</h3>
                {%- elsif _htag == 'h1' -%}
                  <h1 class="blr-row__title">{{ row_heading | escape }}</h1>
                {%- else -%}
                  <h2 class="blr-row__title">{{ row_heading | escape }}</h2>
                {%- endif -%}
                {%- if block.settings.show_view_all -%}
                  <a href="{{ row_blog.url }}" class="blr-row__view-all link">
                    {{ block.settings.view_all_label | default: 'View All' }}
                  </a>
                {%- endif -%}
              </div>

              {%- comment -%}── Article grid ──{%- endcomment -%}
              <div
                id="blr-grid-{{ block.id }}"
                class="blr-grid"
              >
                {%- for article in row_blog.articles limit: block.settings.posts_to_show -%}
                  {%- assign _loading = 'lazy' -%}
                  {%- if forloop.index <= row_cols -%}{%- assign _loading = 'eager' -%}{%- endif -%}
                  {%- render 'card-article-82x',
                    card_article:  article,
                    show_image:    section.settings.show_image,
                    show_date:     section.settings.show_date,
                    show_excerpt:  block.settings.show_excerpt,
                    title_lines:   block.settings.title_lines,
                    excerpt_lines: block.settings.excerpt_lines,
                    img_loading:   _loading,
                    img_sizes:     '(min-width: 990px) 25vw, (min-width: 750px) 40vw, 50vw'
                  -%}
                {%- endfor -%}
              </div>

            </div>

          {%- endif -%}
        {%- endfor -%}

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blog Rows",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
