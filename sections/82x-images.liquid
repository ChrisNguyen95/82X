{%- liquid
  assign block_count = section.blocks | size
-%}

{%- style -%}
  /* ── Padding ── */
  .section-{{ section.id }}-padding {
    padding-top:    {{ section.settings.padding_top    | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top:    {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* ── Grid wrapper ── */
  #Images-{{ section.id }} .img82x-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.gap_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    #Images-{{ section.id }} .img82x-grid {
      gap: {{ section.settings.gap }}px;
    }
    {%- if block_count == 2 -%}
      #Images-{{ section.id }} .img82x-grid {
        grid-template-columns: {%- if section.settings.equal_width -%}1fr 1fr{%- else -%}{{ section.settings.col1_ratio }}fr {{ section.settings.col2_ratio }}fr{%- endif -%};
      }
    {%- endif -%}
  }

  /* ── Image item ── */
  #Images-{{ section.id }} .img82x-item {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius }}px;
    display: block;
  }

  #Images-{{ section.id }} .img82x-item__img-wrap {
    width: 100%;
    overflow: hidden;
    {%- if section.settings.image_ratio == 'adapt' -%}
      /* adapt — ratio per image */
    {%- elsif section.settings.image_ratio == 'square' -%}
      aspect-ratio: 1 / 1;
    {%- elsif section.settings.image_ratio == 'portrait' -%}
      aspect-ratio: 2 / 3;
    {%- elsif section.settings.image_ratio == 'landscape' -%}
      aspect-ratio: 16 / 9;
    {%- elsif section.settings.image_ratio == 'wide' -%}
      aspect-ratio: 4 / 3;
    {%- endif -%}
  }

  #Images-{{ section.id }} .img82x-item__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  #Images-{{ section.id }} .img82x-item:hover .img82x-item__img-wrap img {
    transform: scale(1.03);
  }

  /* ── Overlay ── */
  #Images-{{ section.id }} .img82x-item__overlay {
    position: absolute;
    inset: 0;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  #Images-{{ section.id }} .img82x-item__caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 2.4rem;
    color: {{ section.settings.caption_color }};
    font-family: var(--font-heading-family);
    font-size: {{ section.settings.caption_size }}px;
    font-weight: {{ section.settings.caption_weight }};
    letter-spacing: 0.02em;
    line-height: 1.3;
  }
{%- endstyle -%}

{%- unless section.settings.full_width -%}
  <div class="page-width">
{%- endunless -%}

<div id="Images-{{ section.id }}" class="section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}">
  {%- if section.blocks.size == 0 -%}
    {%- if request.design_mode -%}
      <p style="padding:2rem;text-align:center;opacity:0.5;">{{ 'onboarding.onboarding_title' | t }} — thêm block Image để bắt đầu.</p>
    {%- endif -%}
  {%- else -%}
    <div class="img82x-grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign img     = block.settings.image
          assign link    = block.settings.link
          assign caption = block.settings.caption
          assign tag     = 'div'
          if link != blank
            assign tag = 'a'
          endif
          assign _img_loading = 'lazy'
          if forloop.index == 1
            assign _img_loading = 'eager'
          endif
        -%}

        {%- if link != blank -%}
          <a class="img82x-item" href="{{ link }}" {{ block.shopify_attributes }}>
        {%- else -%}
          <div class="img82x-item" {{ block.shopify_attributes }}>
        {%- endif -%}

          <div class="img82x-item__img-wrap">
            {%- if img != blank -%}
              {%- liquid
                assign img_alt = block.settings.alt
                if img_alt == blank
                  assign img_alt = img.alt
                endif
                if img_alt == blank
                  assign img_alt = shop.name
                endif
              -%}
              {{
                img
                | image_url: width: 1600
                | image_tag:
                  widths: '400, 600, 800, 1000, 1200, 1600',
                  sizes: '(min-width: 1200px) calc(50vw - 6rem), (min-width: 750px) calc(50vw - 4rem), 100vw',
                  alt: img_alt,
                  loading: _img_loading,
                  width: img.width,
                  height: img.height
              }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>

          {%- if section.settings.overlay_opacity > 0 -%}
            <div class="img82x-item__overlay"></div>
          {%- endif -%}

          {%- if caption != blank -%}
            <div class="img82x-item__caption">{{ caption }}</div>
          {%- endif -%}

        {%- if link != blank -%}
          </a>
        {%- else -%}
          </div>
        {%- endif -%}

      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{%- unless section.settings.full_width -%}
  </div>
{%- endunless -%}

{% schema %}
{
  "name": "Images",
  "tag": "section",
  "class": "section",
  "max_blocks": 2,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "adapt",    "label": "Adapt to image" },
        { "value": "square",   "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (2:3)" },
        { "value": "wide",     "label": "Wide (4:3)" },
        { "value": "landscape","label": "Landscape (16:9)" }
      ],
      "default": "adapt"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Corner radius",
      "min": 0, "max": 40, "step": 2, "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "2-column ratio (desktop)"
    },
    {
      "type": "checkbox",
      "id": "equal_width",
      "label": "Equal columns (50/50)",
      "default": true
    },
    {
      "type": "range",
      "id": "col1_ratio",
      "label": "Column 1 ratio",
      "min": 1, "max": 9, "step": 1,
      "default": 1,
      "info": "Áp dụng khi tắt Equal columns"
    },
    {
      "type": "range",
      "id": "col2_ratio",
      "label": "Column 2 ratio",
      "min": 1, "max": 9, "step": 1,
      "default": 1
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between images (desktop)",
      "min": 0, "max": 80, "step": 2, "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap between images (mobile)",
      "min": 0, "max": 40, "step": 2, "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0, "max": 80, "step": 5, "unit": "%",
      "default": 0
    },
    {
      "type": "header",
      "content": "Caption"
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Caption color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "caption_size",
      "label": "Caption font size",
      "min": 12, "max": 48, "step": 2, "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "caption_weight",
      "label": "Caption font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "header",
      "content": "Color scheme"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text",
          "info": "Để trống sẽ dùng alt của ảnh"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (tuỳ chọn)"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (tuỳ chọn)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Images",
      "blocks": [
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
