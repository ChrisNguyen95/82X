{%- liquid
  assign desktop_height = section.settings.desktop_height
  assign mobile_height = section.settings.mobile_height

  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif

  assign has_mobile_img = false
  if section.settings.image_mobile != blank
    assign has_mobile_img = true
  endif

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}

{%- style -%}
/* ─────────────────────────────────────────────
   Hero Split — #HeroSplit-{{ section.id }}
   ───────────────────────────────────────────── */

/* ── WRAPPER ──
   position: relative + overflow: hidden để chứa ảnh absolute.
   Chiều cao đến từ ::before (adapt) hoặc min-height (fixed).
   Không dùng flex trên wrapper vì content-outer là absolute.
──────────────────────────────────────────────── */
#HeroSplit-{{ section.id }} {
  position: relative;
  overflow: hidden;
}

/* ── MOBILE HEIGHT ── */
@media screen and (max-width: 749px) {
  {%- if mobile_height == 'adapt' -%}
    {%- comment -%}
      Dùng ::before padding-bottom trick trực tiếp trên section.
      Chọn tỉ lệ ảnh mobile nếu có, nếu không thì dùng ảnh desktop.
    {%- endcomment -%}
    {%- if has_mobile_img -%}
      #HeroSplit-{{ section.id }}::before {
        content: '';
        display: block;
        padding-bottom: {{ 1 | divided_by: section.settings.image_mobile.aspect_ratio | times: 100 }}%;
      }
    {%- elsif has_image -%}
      #HeroSplit-{{ section.id }}::before {
        content: '';
        display: block;
        padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;
      }
    {%- else -%}
      #HeroSplit-{{ section.id }} { min-height: 48rem; }
    {%- endif -%}
  {%- elsif mobile_height == 'small' -%}
    #HeroSplit-{{ section.id }} { min-height: 36rem; }
  {%- elsif mobile_height == 'medium' -%}
    #HeroSplit-{{ section.id }} { min-height: 48rem; }
  {%- elsif mobile_height == 'large' -%}
    #HeroSplit-{{ section.id }} { min-height: 64rem; }
  {%- elsif mobile_height == 'fullscreen' -%}
    #HeroSplit-{{ section.id }} { min-height: 100svh; }
  {%- endif -%}
}

/* ── DESKTOP HEIGHT ── */
@media screen and (min-width: 750px) {
  {%- if desktop_height == 'adapt' -%}
    {%- if has_image -%}
      #HeroSplit-{{ section.id }}::before {
        content: '';
        display: block;
        padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;
      }
    {%- else -%}
      #HeroSplit-{{ section.id }} { min-height: 56rem; }
    {%- endif -%}
    /* Reset min-height ở desktop adapt để tránh xung đột với mobile min-height */
    #HeroSplit-{{ section.id }} { min-height: 0; }
  {%- elsif desktop_height == 'small' -%}
    #HeroSplit-{{ section.id }} { min-height: 42rem; }
  {%- elsif desktop_height == 'medium' -%}
    #HeroSplit-{{ section.id }} { min-height: 56rem; }
  {%- elsif desktop_height == 'large' -%}
    #HeroSplit-{{ section.id }} { min-height: 72rem; }
  {%- elsif desktop_height == 'fullscreen' -%}
    #HeroSplit-{{ section.id }} { min-height: 100svh; }
  {%- endif -%}
}

/* ── BACKGROUND MEDIA ──
   Luôn position: absolute; inset: 0 để fill toàn bộ section
   (cả khi adapt dùng ::before, cả khi fixed dùng min-height).
──────────────────────────────────────────────── */
#HeroSplit-{{ section.id }} .hero-split__media {
  position: absolute;
  inset: 0;
  z-index: 0;
  overflow: hidden;
}

#HeroSplit-{{ section.id }} .hero-split__media img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: {{ section.settings.image_fit }};
  object-position: {{ section.settings.image_position }};
  display: block;
}

/* desktop / mobile image visibility */
#HeroSplit-{{ section.id }} .hero-split__media--desktop { display: none; }
#HeroSplit-{{ section.id }} .hero-split__media--mobile  { display: block; }

@media screen and (min-width: 750px) {
  #HeroSplit-{{ section.id }} .hero-split__media--desktop { display: block; }
  #HeroSplit-{{ section.id }} .hero-split__media--mobile  { display: none; }
}

/* overlay */
#HeroSplit-{{ section.id }} .hero-split__media::after {
  content: '';
  position: absolute;
  inset: 0;
  background: #000;
  opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  z-index: 1;
  pointer-events: none;
}

/* ── CONTENT LAYER ──
   position: absolute; inset: 0 → overlay lên ảnh nền.
   display: flex để căn chỉnh theo vertical setting.
   padding tạo khoảng cách từ cạnh section.
──────────────────────────────────────────────── */
#HeroSplit-{{ section.id }} .hero-split__content-outer {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  width: 100%;

  /* vertical alignment (mobile) */
  align-items: {%- case section.settings.mobile_vertical -%}
    {%- when 'top' -%}    flex-start
    {%- when 'bottom' -%} flex-end
    {%- else -%}          center
  {%- endcase -%};

  padding: {{ section.settings.padding_top_mobile }}px 0 {{ section.settings.padding_bottom_mobile }}px;
}

@media screen and (min-width: 750px) {
  #HeroSplit-{{ section.id }} .hero-split__content-outer {
    /* vertical alignment (desktop) */
    align-items: {%- case section.settings.desktop_vertical -%}
      {%- when 'top' -%}    flex-start
      {%- when 'bottom' -%} flex-end
      {%- else -%}          center
    {%- endcase -%};

    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
}

/* ── PAGE-WIDTH WRAPPER ── */
#HeroSplit-{{ section.id }} .hero-split__page-width {
  width: 100%;
  max-width: {{ settings.page_width }}px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

@media screen and (min-width: 750px) {
  #HeroSplit-{{ section.id }} .hero-split__page-width {
    padding: 0 5rem;
  }
}

/* ── CONTENT BOX ── */
.hero-split__box {
  display: flex;
  flex-direction: column;
  gap: 2rem;

  text-align: {{ section.settings.mobile_align }};

  max-width: {{ section.settings.content_max_width_mobile }}%;
  width: 100%;
}

@media screen and (min-width: 750px) {
  .hero-split__box {
    text-align: {{ section.settings.desktop_align }};
    max-width: {{ section.settings.content_max_width }}%;

    {%- if section.settings.desktop_horizontal == 'left' -%}
      margin-right: auto;
    {%- elsif section.settings.desktop_horizontal == 'center' -%}
      margin-left: auto; margin-right: auto;
    {%- elsif section.settings.desktop_horizontal == 'right' -%}
      margin-left: auto;
    {%- endif -%}
  }
}

/* show-text-box: when disabled, box has no background / padding */
{%- if section.settings.show_text_box -%}
  .hero-split__box {
    padding: 2.4rem;
    border-radius: var(--border-radius, 0.4rem);
  }
  @media screen and (min-width: 750px) {
    .hero-split__box { padding: 4rem 4.8rem; }
  }
{%- endif -%}

/* ── SUBTEXT ── */
.hero-split__subtext {
  margin: 0;
}

/* ── HEADING ── */
.hero-split__heading { margin: 0; }

/* ── BODY TEXT ── */
.hero-split__text { margin: 0; }

/* ── BUTTONS ── */
.hero-split__buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 1.2rem;
  justify-content: {% if section.settings.mobile_align == 'center' %}center{% elsif section.settings.mobile_align == 'right' %}flex-end{% else %}flex-start{% endif %};
}

@media screen and (min-width: 750px) {
  .hero-split__buttons {
    justify-content: {% if section.settings.desktop_align == 'center' %}center{% elsif section.settings.desktop_align == 'right' %}flex-end{% else %}flex-start{% endif %};
  }
}

/* ── ICONS ROW ── */
.hero-split__icons {
  display: flex;
  flex-wrap: wrap;
  gap: 1.6rem 2.8rem;
  align-items: flex-start;
  justify-content: {% if section.settings.mobile_align == 'center' %}center{% elsif section.settings.mobile_align == 'right' %}flex-end{% else %}flex-start{% endif %};
}

@media screen and (min-width: 750px) {
  .hero-split__icons {
    justify-content: {% if section.settings.desktop_align == 'center' %}center{% elsif section.settings.desktop_align == 'right' %}flex-end{% else %}flex-start{% endif %};
  }
}

.hero-split__icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  text-align: center;
  max-width: 8rem;
}

.hero-split__icon-item .icon-img {
  width: {{ section.settings.icon_size }}px;
  height: {{ section.settings.icon_size }}px;
  object-fit: contain;
  display: block;
  flex-shrink: 0;
}

.hero-split__icon-label {
  display: block;
  font-size: 1.1rem;
  font-weight: 600;
  font-style: italic;
  line-height: 1.3;
  margin: 0;
  word-break: break-word;
}
{%- endstyle -%}

<div
  id="HeroSplit-{{ section.id }}"
  class="hero-split{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
>

  {%- comment -%}─── BACKGROUND IMAGES ───{%- endcomment -%}

  {%- comment -%} Desktop image {%- endcomment -%}
  <div class="hero-split__media hero-split__media--desktop">
    {%- if has_image -%}
      {%- assign image_height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio -%}
      {{
        section.settings.image
        | image_url: width: 3840
        | image_tag:
          width: section.settings.image.width,
          height: image_height,
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
          fetchpriority: fetch_priority,
          alt: section.settings.image.alt | escape
      }}
    {%- else -%}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  {%- comment -%} Mobile image (falls back to desktop) {%- endcomment -%}
  <div class="hero-split__media hero-split__media--mobile">
    {%- if has_mobile_img -%}
      {%- assign mobile_image_height = section.settings.image_mobile.width | divided_by: section.settings.image_mobile.aspect_ratio -%}
      {{
        section.settings.image_mobile
        | image_url: width: 1200
        | image_tag:
          width: section.settings.image_mobile.width,
          height: mobile_image_height,
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1200',
          fetchpriority: fetch_priority,
          alt: section.settings.image_mobile.alt | escape
      }}
    {%- elsif has_image -%}
      {%- assign image_height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio -%}
      {{
        section.settings.image
        | image_url: width: 1200
        | image_tag:
          width: section.settings.image.width,
          height: image_height,
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1200',
          fetchpriority: fetch_priority,
          alt: section.settings.image.alt | escape
      }}
    {%- else -%}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  {%- comment -%}─── CONTENT LAYER ───{%- endcomment -%}
  <div class="hero-split__content-outer">
    <div class="hero-split__page-width">
      <div class="hero-split__box{% if section.settings.show_text_box %} color-{{ section.settings.color_scheme }} gradient{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">

        {%- comment -%} Render blocks (subtext, heading, text, buttons) {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'subtext' -%}
              {%- if block.settings.subtext != blank -%}
                <p
                  class="hero-split__subtext {{ block.settings.subtext_style }}"
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.subtext | escape }}
                </p>
              {%- endif -%}

            {%- when 'heading' -%}
              {%- if block.settings.heading != blank -%}
                <h2
                  class="hero-split__heading inline-richtext {{ block.settings.heading_size }}"
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.heading }}
                </h2>
              {%- endif -%}

            {%- when 'text' -%}
              {%- if block.settings.text != blank -%}
                <div
                  class="hero-split__text rte {{ block.settings.text_style }}"
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.text }}
                </div>
              {%- endif -%}

            {%- when 'buttons' -%}
              {%- if block.settings.button_label_1 != blank or block.settings.button_label_2 != blank -%}
                <div class="hero-split__buttons" {{ block.shopify_attributes }}>
                  {%- if block.settings.button_label_1 != blank -%}
                    <a
                      {% if block.settings.button_link_1 != blank %}href="{{ block.settings.button_link_1 }}"{% else %}role="link" aria-disabled="true"{% endif %}
                      class="button{% if block.settings.button_style_secondary_1 %} button--secondary{% else %} button--primary{% endif %}"
                    >
                      {{- block.settings.button_label_1 | escape -}}
                    </a>
                  {%- endif -%}
                  {%- if block.settings.button_label_2 != blank -%}
                    <a
                      {% if block.settings.button_link_2 != blank %}href="{{ block.settings.button_link_2 }}"{% else %}role="link" aria-disabled="true"{% endif %}
                      class="button{% if block.settings.button_style_secondary_2 %} button--secondary{% else %} button--primary{% endif %}"
                    >
                      {{- block.settings.button_label_2 | escape -}}
                    </a>
                  {%- endif -%}
                </div>
              {%- endif -%}

            {%- when 'icon_list' -%}
              {%- comment -%}
                icon_list block holds up to 8 icon+label pairs inline
              {%- endcomment -%}
              {%- assign has_any_icon = false -%}
              {%- for i in (1..8) -%}
                {%- assign icon_key = 'icon_' | append: i -%}
                {%- assign label_key = 'label_' | append: i -%}
                {%- if block.settings[icon_key] != blank or block.settings[label_key] != blank -%}
                  {%- assign has_any_icon = true -%}
                {%- endif -%}
              {%- endfor -%}

              {%- if has_any_icon -%}
                <div class="hero-split__icons" {{ block.shopify_attributes }}>
                  {%- for i in (1..8) -%}
                    {%- assign icon_key   = 'icon_'  | append: i -%}
                    {%- assign label_key  = 'label_' | append: i -%}
                    {%- if block.settings[icon_key] != blank or block.settings[label_key] != blank -%}
                      <div class="hero-split__icon-item">
                        {%- if block.settings[icon_key] != blank -%}
                          {{
                            block.settings[icon_key]
                            | image_url: width: 120
                            | image_tag:
                              class: 'icon-img',
                              loading: 'lazy',
                              widths: '60, 80, 120',
                              alt: block.settings[label_key] | escape
                          }}
                        {%- endif -%}
                        {%- if block.settings[label_key] != blank -%}
                          <span class="hero-split__icon-label">
                            {{ block.settings[label_key] | escape }}
                          </span>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}

          {%- endcase -%}
        {%- endfor -%}

      </div>
    </div>
  </div>

</div>

{% schema %}
{
  "name": "Hero Split",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image",
      "info": "Leave blank to use desktop image"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        { "value": "cover",   "label": "Cover (fill & crop)" },
        { "value": "contain", "label": "Contain (show full image)" }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image focal point",
      "options": [
        { "value": "top left",      "label": "Top left" },
        { "value": "top center",    "label": "Top center" },
        { "value": "top right",     "label": "Top right" },
        { "value": "center left",   "label": "Middle left" },
        { "value": "center center", "label": "Middle center" },
        { "value": "center right",  "label": "Middle right" },
        { "value": "bottom left",   "label": "Bottom left" },
        { "value": "bottom center", "label": "Bottom center" },
        { "value": "bottom right",  "label": "Bottom right" }
      ],
      "default": "center center"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Image overlay opacity",
      "default": 0
    },
    {
      "type": "header",
      "content": "Height — Desktop"
    },
    {
      "type": "select",
      "id": "desktop_height",
      "label": "Desktop height",
      "options": [
        { "value": "adapt",      "label": "Adapt to image" },
        { "value": "small",      "label": "Small  (420px)" },
        { "value": "medium",     "label": "Medium (560px)" },
        { "value": "large",      "label": "Large  (720px)" },
        { "value": "fullscreen", "label": "Full screen" }
      ],
      "default": "large"
    },
    {
      "type": "header",
      "content": "Height — Mobile"
    },
    {
      "type": "select",
      "id": "mobile_height",
      "label": "Mobile height",
      "options": [
        { "value": "adapt",      "label": "Adapt to image" },
        { "value": "small",      "label": "Small  (360px)" },
        { "value": "medium",     "label": "Medium (480px)" },
        { "value": "large",      "label": "Large  (640px)" },
        { "value": "fullscreen", "label": "Full screen" }
      ],
      "default": "adapt"
    },
    {
      "type": "header",
      "content": "Content position"
    },
    {
      "type": "select",
      "id": "desktop_vertical",
      "label": "Vertical alignment (desktop)",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "middle"
    },
    {
      "type": "select",
      "id": "mobile_vertical",
      "label": "Vertical alignment (mobile)",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "middle"
    },
    {
      "type": "select",
      "id": "desktop_horizontal",
      "label": "Horizontal (desktop)",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "desktop_align",
      "label": "Text alignment (desktop)",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "mobile_align",
      "label": "Text alignment (mobile)",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Content max width (desktop)",
      "default": 50
    },
    {
      "type": "range",
      "id": "content_max_width_mobile",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Content max width (mobile)",
      "default": 100
    },
    {
      "type": "header",
      "content": "Content box"
    },
    {
      "type": "checkbox",
      "id": "show_text_box",
      "label": "Show background box",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Box color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 32,
      "max": 72,
      "step": 4,
      "unit": "px",
      "label": "Icon size",
      "default": 48
    },
    {
      "type": "header",
      "content": "Padding — Desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    },
    {
      "type": "header",
      "content": "Padding — Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "subtext",
      "name": "Subtext",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "Start Your Premium Collagen Journey For"
        },
        {
          "type": "select",
          "id": "subtext_style",
          "label": "Style",
          "options": [
            { "value": "body",                        "label": "Body" },
            { "value": "subtitle",                    "label": "Subtitle" },
            { "value": "caption-with-letter-spacing", "label": "Caption" }
          ],
          "default": "caption-with-letter-spacing"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Reveal Your Natural Glow - Just $5 Per Day"
        },
