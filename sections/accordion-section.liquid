{{- 'section-heading.css' | asset_url | stylesheet_tag -}}

{%- style -%}
/* ══════════════════════════════════════════════════════════════
   Accordion Section — #AccordionSection-{{ section.id }}
   Dual mode:
   • "Benefits" — white/plain bg, heading + tag pills + subtext + accordion
   • "FAQ"       — card with rounded bg, heading + accordion
   ══════════════════════════════════════════════════════════════ */

/* ── Section wrapper ── */
#AccordionSection-{{ section.id }} {
  background-color: {{ section.settings.section_bg }};
  padding-top:    {{ section.settings.padding_top    | times: 0.75 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
}
@media screen and (min-width: 750px) {
  #AccordionSection-{{ section.id }} {
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
}

/* ── Card wrapper (when card_style = true) ── */
#AccordionSection-{{ section.id }} .ac-card {
  background-color: {{ section.settings.card_bg }};
  border-radius: {{ section.settings.card_radius }}px;
  padding: {{ section.settings.card_padding_v | times: 0.75 | round: 0 }}px {{ section.settings.card_padding_h | times: 0.75 | round: 0 }}px;
}
@media screen and (min-width: 750px) {
  #AccordionSection-{{ section.id }} .ac-card {
    padding: {{ section.settings.card_padding_v }}px {{ section.settings.card_padding_h }}px;
  }
}

/* ── Header area ── */
#AccordionSection-{{ section.id }} .ac-header {
  text-align: {{ section.settings.text_align }};
  margin-bottom: 4rem;
}
@media screen and (min-width: 990px) {
  #AccordionSection-{{ section.id }} .ac-header {
    margin-bottom: 5rem;
  }
}
/* section-heading inside ac-header — reset its own margin */
#AccordionSection-{{ section.id }} .ac-header .section-heading {
  margin-bottom: 1.6rem;
}

/* Heading */
#AccordionSection-{{ section.id }} .section-heading__title {
  margin: 0 auto;
  color: {{ section.settings.heading_color }};
  {%- if section.settings.heading_max_width > 0 -%}
  max-width: {{ section.settings.heading_max_width }}px;
  {%- endif -%}
}

/* Tags row */
#AccordionSection-{{ section.id }} .ac-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  margin-top: 2rem;
  justify-content: {{ section.settings.text_align | replace: 'left', 'flex-start' | replace: 'center', 'center' | replace: 'right', 'flex-end' }};
}

/* Tag pill — fixed height 44px, padding 9px 30px */
#AccordionSection-{{ section.id }} .ac-tag {
  display: inline-flex;
  align-items: center;
  height: 4.4rem;
  padding: 0.9rem 3rem;
  border-radius: 10rem;
  background-color: {{ section.settings.tag_bg }};
  color: {{ section.settings.tag_color }};
  font-size: 1.2rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  white-space: nowrap;
}

/* Subtext */
#AccordionSection-{{ section.id }} .ac-subtext {
  margin: 1.6rem 0 0;
  font-size: 1.4rem;
  color: {{ section.settings.subtext_color }};
  line-height: 1.6;
}

/* ── Accordion list ── */
#AccordionSection-{{ section.id }} .ac-list {
  {%- if section.settings.list_max_width > 0 -%}
  max-width: {{ section.settings.list_max_width }}px;
  margin-left: auto;
  margin-right: auto;
  {%- endif -%}
}

/* ── Accordion item ── */
#AccordionSection-{{ section.id }} .ac-item {
  border-bottom: 0.1rem solid {{ section.settings.divider_color }};
}
#AccordionSection-{{ section.id }} .ac-item:first-child {
  border-top: 0.1rem solid {{ section.settings.divider_color }};
}

/* ── Summary (clickable row) ── */
#AccordionSection-{{ section.id }} .ac-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.6rem;
  padding: 2rem 0;
  cursor: pointer;
  list-style: none;
  user-select: none;
  -webkit-tap-highlight-color: transparent;
}
#AccordionSection-{{ section.id }} .ac-summary::-webkit-details-marker { display: none; }

#AccordionSection-{{ section.id }} .ac-summary__title {
  flex: 1;
  font-size: 1.6rem;
  font-weight: 600;
  color: {{ section.settings.title_color }};
  line-height: 1.4;
}
@media screen and (min-width: 750px) {
  #AccordionSection-{{ section.id }} .ac-summary__title {
    font-size: 1.8rem;
  }
}

/* ── +/− Icon ── */
#AccordionSection-{{ section.id }} .ac-icon {
  flex-shrink: 0;
  position: relative;
  width: 2rem;
  height: 2rem;
  color: {{ section.settings.icon_color }};
}
/* Horizontal bar — always visible */
#AccordionSection-{{ section.id }} .ac-icon::before {
  content: '';
  position: absolute;
  width: 100%;
  height: 0.2rem;
  background: currentColor;
  border-radius: 0.1rem;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
}
/* Vertical bar — visible when closed, hidden when open */
#AccordionSection-{{ section.id }} .ac-icon::after {
  content: '';
  position: absolute;
  width: 0.2rem;
  height: 100%;
  background: currentColor;
  border-radius: 0.1rem;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
  transition: opacity 0.2s ease, transform 0.2s ease;
}
#AccordionSection-{{ section.id }} details[open] .ac-icon::after {
  opacity: 0;
  transform: translateX(-50%) scaleY(0);
}

/* ── Accordion body ── */
#AccordionSection-{{ section.id }} .ac-body {
  padding-bottom: 2rem;
  font-size: 1.4rem;
  line-height: 1.7;
  color: {{ section.settings.body_color }};
}
#AccordionSection-{{ section.id }} .ac-body p { margin: 0; }
#AccordionSection-{{ section.id }} .ac-body p + p { margin-top: 0.8em; }

{%- endstyle -%}

<section
  id="AccordionSection-{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} gradient{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
>
  <div class="page-width">

    {%- comment -%}── Card wrapper (conditional) ──{%- endcomment -%}
    {%- if section.settings.card_style -%}<div class="ac-card">{%- endif -%}

    {%- comment -%}── Header ──{%- endcomment -%}
    {%- assign has_heading = false -%}
    {%- assign has_tags    = false -%}
    {%- unless section.settings.heading == blank -%}{%- assign has_heading = true -%}{%- endunless -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'tag' -%}{%- assign has_tags = true -%}{%- endif -%}
    {%- endfor -%}

    {%- if has_heading or has_tags or section.settings.subtext != blank -%}
      <div class="ac-header">

        {%- if has_heading -%}
          {%- render 'section-heading',
            heading:      section.settings.heading,
            heading_tag:  section.settings.heading_tag,
            heading_size: section.settings.heading_size
          -%}
        {%- endif -%}

        {%- comment -%}── Tag pills ──{%- endcomment -%}
        {%- if has_tags -%}
          <div class="ac-tags" role="list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'tag' -%}
                <span class="ac-tag" role="listitem" {{ block.shopify_attributes }}>
                  {{- block.settings.label | escape -}}
                </span>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%}── Subtext ──{%- endcomment -%}
        {%- unless section.settings.subtext == blank -%}
          <p class="ac-subtext">{{ section.settings.subtext | escape }}</p>
        {%- endunless -%}

      </div>
    {%- endif -%}

    {%- comment -%}── Accordion list ──{%- endcomment -%}
    <div class="ac-list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'item' -%}
          <details
            class="ac-item"
            {% if block.settings.open_by_default %}open{% endif %}
            {{ block.shopify_attributes }}
          >
            <summary class="ac-summary">
              <span class="ac-summary__title font-heading">{{ block.settings.title | escape }}</span>
              <span class="ac-icon" aria-hidden="true"></span>
            </summary>
            <div class="ac-body rte">
              {{ block.settings.content }}
            </div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.card_style -%}</div>{%- endif -%}

  </div>
</section>

{% schema %}
{
