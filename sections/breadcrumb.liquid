{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: calc({{ section.settings.padding_top }}px * 0.54);
    padding-bottom: calc({{ section.settings.padding_bottom }}px * 0.54);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    font-size: {{ section.settings.font_size }}px;
    list-style: none;
    margin: 0;
    padding: 0;
    text-transform: uppercase;
  }

  .breadcrumb a {
    color: {{ section.settings.link_color }};
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .breadcrumb__sep {
    color: {{ section.settings.sep_color }};
    user-select: none;
    padding: 0 1rem
  }

  .breadcrumb__current {
    color: {{ section.settings.current_color }};
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="{% if section.settings.full_width %}{% else %}page-width{% endif %} section-{{ section.id }}-padding">
    <nav class="breadcrumb" aria-label="Breadcrumb">

      {%- comment -%} Home {%- endcomment -%}
      <a href="{{ routes.root_url }}">
        {%- if section.settings.show_home_icon -%}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="vertical-align: -2px;"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        {%- endif -%}
        {{ section.settings.home_label | default: 'Home' }}
      </a>

      {%- comment -%} Page-type specific crumbs {%- endcomment -%}
      {%- if template == 'product' -%}

        {%- if product.collections.size > 0 -%}
          {%- assign main_collection = product.collections | first -%}
          <span class="breadcrumb__sep" aria-hidden="true">{{ section.settings.separator }}</span>
          <a href="{{ main_collection.url }}">{{ main_collection.title }}</a>
        {%- endif -%}
        <span class="breadcrumb__sep" aria-hidden="true">{{ section.settings.separator }}</span>
        <span class="breadcrumb__current" aria-current="page">{{ product.title }}</span>

      {%- elsif template == 'collection' -%}

        <span class="breadcrumb__sep" aria-hidden="true">{{ section.settings.separator }}</span>
        <span class="breadcrumb__current" aria-current="page">{{ collection.title }}</span>

      {%- elsif template == 'blog' -%}

        <span class="breadcrumb__sep" aria-hidden="true">{{ section.settings.separator }}</span>
        <span class="breadcrumb__current" aria-current="page">{{ blog.title }}</span>

      {%- elsif template == 'article' -%}

        <span class="breadcrumb__sep" aria-hidden="true">{{ section.settings.separator }}</span>
        <a href="{{ blog.url }}">{{ blog.title }}</a>
        <span class="breadcrumb__sep" aria-hidden="true">{{ section.settings.separator }}</span>
        <span class="breadcrumb__current" aria-current="page">{{ article.title }}</span>

      {%- elsif template == 'page' -%}

        <span class="breadcrumb__sep" aria-hidden="true">{{ section.settings.separator }}</span>
        <span class="breadcrumb__current" aria-current="page">{{ page.title }}</span>

      {%- elsif template == 'search' -%}

        <span class="breadcrumb__sep" aria-hidden="true">{{ section.settings.separator }}</span>
        <span class="breadcrumb__current" aria-current="page">{{ 'general.search.title' | t | default: 'Search' }}</span>

      {%- elsif template == 'cart' -%}

        <span class="breadcrumb__sep" aria-hidden="true">{{ section.settings.separator }}</span>
        <span class="breadcrumb__current" aria-current="page">{{ 'sections.cart.title' | t | default: 'Cart' }}</span>

      {%- endif -%}

    </nav>
  </div>
</div>

{% schema %}
{
  "name": "Breadcrumb",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Labels"
    },
    {
      "type": "text",
      "id": "home_label",
      "label": "Home label",
      "default": "Home"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "/"
    },
    {
      "type": "checkbox",
      "id": "show_home_icon",
      "label": "Show home icon",
      "default": false
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 13
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "sep_color",
      "label": "Separator color",
      "default": "#9ca3af"
    },
    {
      "type": "color",
      "id": "current_color",
      "label": "Current page color",
      "default": "#111827"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Breadcrumb"
    }
  ]
}
{% endschema %}
