{
  "sections": {
    "blog-header": {
      "type": "82x-blog-header",
      "blocks": {
        "link-featured": {
          "type": "nav_link",
          "settings": {
            "label": "Featured"
          }
        },
        "link-skin": {
          "type": "nav_link",
          "settings": {
            "label": "Skin & Anti-Aging"
          }
        },
        "link-ingredient": {
          "type": "nav_link",
          "settings": {
            "label": "Ingredient-Focused Content"
          }
        }
      },
      "block_order": ["link-featured", "link-skin", "link-ingredient"],
      "settings": {
        "heading": "Learning Center",
        "heading_tag": "h1",
        "heading_size": "h0",
        "heading_italic": true,
        "heading_align": "center",
        "show_search": true,
        "search_placeholder": "Search learning center",
        "padding_top": 48,
        "padding_bottom": 0
      }
    },
    "featured-articles": {
      "type": "82x-blog-posts",
      "settings": {
        "heading": "Featured",
        "heading_size": "h2",
        "post_limit": 6,
        "columns_desktop": 3,
        "show_view_all": false,
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "blog-content": {
      "type": "82x-blog-content",
      "settings": {
        "articles_per_page": 9,
        "columns_desktop": 3,
        "columns_mobile": "1",
        "image_ratio": "16/9",
        "card_radius": 12,
        "title_lines": 3,
        "show_image": true,
        "show_date": true,
        "show_excerpt": true,
        "excerpt_lines": 3,
        "sidebar_title": "Shop 82X Favorites",
        "sidebar_width": 20,
        "padding_top": 48,
        "padding_bottom": 60
      }
    }
  },
  "order": [
    "blog-header",
    "featured-articles",
    "blog-content"
  ]
}
