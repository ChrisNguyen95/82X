        "text_6gcinX": {
          "type": "text",
          "settings": {
            "text": "<p>To redefine beauty as a daily ritual from within — not a surface solution. We are committed to bringing the essence of Japanese beauty philosophy to the world through advanced liquid collagen, inspired by the spirit of Sakura.<\/p><p>Our mission is to help women nourish their bodies, restore skin vitality, and awaken a natural, lasting radiance — empowering them to feel confident, balanced, and beautiful from the inside out.<\/p>"
          }
        }
