    "product_faqs": {
      "type": "collapsible-content",
      "blocks": {
        "faq1": {
          "type": "collapsible_row",
          "settings": {
            "heading": "What Are The Benefits Of 82X Sakura Placenta?",
            "icon": "none",
            "row_content": "<p>82X Sakura Placenta is formulated to brighten skin, reduce pigmentation, support collagen production, and deliver a more even, radiant complexion within weeks of consistent use.</p>"
          }
        },
        "faq2": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How Should I Take 82X Sakura Placenta?",
            "icon": "none",
            "row_content": "<p>Drink one bottle (30ml) per day, preferably on an empty stomach in the morning for best absorption. Results are typically visible within 3–4 weeks of daily use.</p>"
          }
        },
        "faq3": {
          "type": "collapsible_row",
          "settings": {
            "heading": "How Long Does It Take To See Results?",
            "icon": "none",
            "row_content": "<p>Most customers notice improvements in skin hydration and radiance within 2–3 weeks. Optimal results for firmness and fine line reduction are seen after 4–8 weeks of consistent daily use.</p>"
          }
        },
        "faq4": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Who Should Use This Product?",
            "icon": "none",
            "row_content": "<p>82X is suitable for adults of all skin types looking to improve skin hydration, firmness, brightness, and overall appearance. Consult a physician if pregnant or nursing.</p>"
          }
        }
      },
      "block_order": ["faq1","faq2","faq3","faq4"],
      "settings": {
        "heading": "FAQs",
        "heading_size": "h1",
        "heading_alignment": "center",
        "layout": "none",
